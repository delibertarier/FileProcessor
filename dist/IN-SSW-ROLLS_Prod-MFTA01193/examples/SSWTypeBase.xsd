e>			</xs:element>			<xs:element name="fieldname">				<xs:annotation>					<xs:documentation>name of the customer defined field >see restriction</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="16"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="value" minOccurs="0">				<xs:annotation>					<xs:documentation>value of the field.Always send as a string.In the template it will be defined what the type of the field is.</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="1000"/>					</xs:restriction>				</xs:simpleType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:element name="type"/>	<xs:simpleType name="businessUnitType">		<xs:annotation>			<xs:documentation>Types defines Business Unit</xs:documentation>		</xs:annotation>		<xs:restriction base="xs:string">			<xs:maxLength value="16"/>		</xs:restriction>	</xs:simpleType>	<xs:simpleType name="packageTypeToStockLevelType">		<xs:restriction base="xs:decimal">			<xs:totalDigits value="18"/>			<xs:fractionDigits value="3"/>		</xs:restriction>	</xs:simpleType>	<xs:complexType name="Permissions">		<xs:annotation>			<xs:documentation> Permissiontable</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="Permission" minOccurs="0" maxOccurs="unbounded">				<xs:complexType>					<xs:sequence>						<xs:element name="permissionType" type="permissionType"/>						<xs:element name="validFrom" type="xs:date" minOccurs="0"/>						<xs:element name="validTill" type="xs:date"/>						<xs:choice minOccurs="0">							<xs:element name="Declarant">								<xs:complexType>									<xs:sequence>										<xs:element name="declarantStatus">											<xs:simpleType>												<xs:restriction base="xs:string">													<xs:maxLength value="1"/>												</xs:restriction>											</xs:simpleType>										</xs:element>									</xs:sequence>								</xs:complexType>							</xs:element>							<xs:element name="Document">								<xs:complexType>									<xs:sequence>										<xs:element name="documentCode">											<xs:simpleType>												<xs:restriction base="xs:string">													<xs:maxLength value="16"/>												</xs:restriction>											</xs:simpleType>										</xs:element>										<xs:element name="documentReference">											<xs:simpleType>												<xs:restriction base="xs:string">													<xs:maxLength value="35"/>												</xs:restriction>											</xs:simpleType>										</xs:element>									</xs:sequence>								</xs:complexType>							</xs:element>						</xs:choice>					</xs:sequence>				</xs:complexType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="EmcsRor">		<xs:annotation>			<xs:documentation>Emcs Report of Reciept</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="indicatorOfShortageOrExcess" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:enumeration value="S"/>						<xs:enumeration value="E"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="observedShortageOrExcess" minOccurs="0">				<xs:simpleType>					<xs:restriction base="netMass">						<xs:totalDigits value="15" fixed="false"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="refusedQuantity" type="netMass" minOccurs="0"/>			<xs:element name="UnsatisfactoryReason" minOccurs="0">				<xs:complexType>					<xs:sequence>						<xs:element name="unsatisfactoryReasonCode" minOccurs="0">							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:length value="1"/>									<xs:enumeration value="0"/>									<xs:enumeration value="1"/>									<xs:enumeration value="2"/>									<xs:enumeration value="3"/>									<xs:enumeration value="4"/>