originCountry"/>			<xs:element name="stockAmount">				<xs:simpleType>					<xs:restriction base="netMass">						<xs:totalDigits value="18"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="InboundReferences">				<xs:complexType>					<xs:sequence>						<xs:element name="DossierID">							<xs:complexType>								<xs:sequence>									<xs:element name="inboundDossierID">										<xs:annotation>											<xs:documentation>Internal ID of the inbound dossier</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="inboundDossierLinkID" minOccurs="0">										<xs:annotation>											<xs:documentation>External Reference of the inbound dossier</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="DossierLineID">										<xs:complexType>											<xs:sequence>												<xs:element name="inboundDossierLineID">													<xs:annotation>														<xs:documentation>Internal ID of the inbound dossier</xs:documentation>													</xs:annotation>												</xs:element>												<xs:element name="inboundDossierLineLinkID" minOccurs="0">													<xs:annotation>														<xs:documentation>External Reference of the inbound dossier</xs:documentation>													</xs:annotation>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="ReturnDeclarationType">		<xs:annotation>			<xs:documentation>DeclarationType to return info from the streamliner</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="typeDeclaration">				<xs:simpleType>					<xs:restriction base="code">						<xs:maxLength value="2"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="declarationID" type="declarationIDType"/>			<xs:element name="customsMainReferenceNumber" minOccurs="0">				<xs:simpleType>					<xs:restriction base="customsMainReferenceNumber"/>				</xs:simpleType>			</xs:element>			<xs:element name="status" type="declarationStatusType" minOccurs="0"/>			<xs:element name="acceptanceDate" minOccurs="0">				<xs:simpleType>					<xs:restriction base="acceptanceDate"/>				</xs:simpleType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="ReturnDeclarationTypeEUC">		<xs:annotation>			<xs:documentation>DeclarationType to return info from the streamliner</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="typeDeclaration">				<xs:simpleType>					<xs:restriction base="code">						<xs:maxLength value="2"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="declarationID" type="declarationIDType"/>			<xs:element name="GUID" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="36"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="procedureType" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="2"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="LRN" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="44"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="customsMainReferenceNumber" minOccurs="0">				<xs:simpleType>					<xs:restriction base="customsMainReferenceNumber"/>				</xs:simpleType>			</xs:element>			<xs:element name="status" type="declarationStatusType" minOccurs="0"/>			<xs:element name="acceptanceDate" minOccurs="0">				<xs:simpleType>					<xs:restriction base="acceptanceDate"/>				</xs:simpleType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="ProductConversionType">		<xs:sequence>			<xs:element name="buom" type="uomType">				<xs:annotation>					<xs:documentation>Base unit of measurement</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="auom" type="uomType">				<xs:annotation>					<xs:documentation>alternative unit of measurement</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="factor" type="uomFactorType">				<xs:annotation>					<xs:documentation>1buom= x.auom</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="codelist" minOccurs="0">				<xs:annotation>					<xs:documentation>example ICL32 for codelist Supplemantary Units</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="32"/>					</xs:restriction>				</xs:simpleType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="ProductType">		<xs:annotation>			<xs:documentation>Type defining a Product</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="code">				<xs:annotation>					<xs:documentation>Unique identification of one specific product. Capitalized</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="code2" minOccurs="0">				<xs:annotation>					<xs:documentation>Capitalized</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="groupingCode" minOccurs="0">				<xs:annotation>					<xs:documentation>Groupingcode can be used as a mastercode</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="consolCode" minOccurs="0">				<xs:annotation>					<xs:documentation>Code used to have a split level on a declaration (different codes will not be consolidated)</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="description" minOccurs="0">				<xs:annotation>					<xs:documentation>Capitalized</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="500"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="netmass" type="netMass" minOccurs="0">				<xs:annotation>					<xs:documentation>Default value for this product.  Use only if product has always the same weight.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="Defaults" minOccurs="0">				<xs:complexType>					<xs:sequence>						<xs:element name="defaultCountryOfOrigin" type="originCountry" minOccurs="0">							<xs:annotation>								<xs:documentation>Use only if product always comes from the same origin.  For example when the product code is coded with the country of origin.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="defaultGrossmass" type="grossMass" minOccurs="0"/>						<xs:element name="defaultPrice" type="invoiceAmount" minOccurs="0"/>						<xs:element name="volumeSingleItem" type="netMass" minOccurs="0">							<xs:annotation>								<xs:documentation>The volume in liter for a single item. Example for a bottle of wine it will be 0.75</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="DefaultCharges" type="ChargesType" minOccurs="0"/>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="iprProductType" minOccurs="0">				<xs:annotation>					<xs:documentation>0 or empty= regular product1 = Final Prodcut2 = Raw material</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:integer">						<xs:totalDigits value="1"/>						<xs:enumeration value="0"/>						<xs:enumeration value="1"/>						<xs:enumeration value="2"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="attributeProductType" minOccurs="0">				<xs:annotation>					<xs:documentation>Indicates the usage of the serialnumberfield is required that will range for picking purpose0 or empty: no extra info required(default)1: product requires serial nr ex.chassis (unique value)2: product requires a lot/batch nr(additional range for picking)3: product requiers a reference. Only mandatory on the inboundlines</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:integer"/>				</xs:simpleType>			</xs:element>			<xs:element name="firstAdditionalCommodity" minOccurs="0">				<xs:simpleType>					<xs:restriction base="firstAdditionalCommodity">						<xs:minLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="secondAdditionalCommodity" minOccurs="0">				<xs:simpleType>					<xs:restriction base="secondAdditionalCommodity">						<xs:minLength value="4"/>						<xs:maxLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="nationalAdditionalCommodity1" minOccurs="0">				<xs:simpleType>					<xs:restriction base="nationalAdditionalCommodity1">						<xs:minLength value="4"/>						<xs:maxLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="nationalAdditionalCommodity2" minOccurs="0">				<xs:simpleType>					<xs:restriction base="nationalAdditionalCommodity2">						<xs:minLength value="4"/>						<xs:maxLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="nationalAdditionalCommodity3" minOccurs="0">				<xs:simpleType>					<xs:restriction base="nationalAdditionalCommodity3">						<xs:minLength value="4"/>						<xs:maxLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="Export" minOccurs="0">				<xs:complexType>					<xs:sequence>						<xs:element name="firstAdditionalCommodity" minOccurs="0">							<xs:simpleType>								<xs:restriction base="firstAdditionalCommodity">									<xs:minLength value="4"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="secondAdditionalCommodity" minOccurs="0">							<xs:simpleType>								<xs:restriction base="secondAdditionalCommodity">									<xs:minLength value="4"/>									<xs:maxLength value="4"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="nationalAdditionalCommodity1" minOccurs="0">							<xs:simpleType>								<xs:restriction base="nationalAdditionalCommodity1">									<xs:minLength value="4"/>									<xs:maxLength value="4"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="nationalAdditionalCommodity2" minOccurs="0">							<xs:simpleType>								<xs:restriction base="nationalAdditionalCommodity2">									<xs:minLength value="4"/>									<xs:maxLength value="4"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="nationalAdditionalCommodity3" minOccurs="0">							<xs:simpleType>								<xs:restriction base="nationalAdditionalCommodity3">									<xs:minLength value="4"/>									<xs:maxLength value="4"/>								</xs:restriction>							</xs:simpleType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="bioLicenseRequired" type="booleanType" minOccurs="0">				<xs:annotation>					<xs:documentation>Product always require a bio - license write off form.</xs:documentation>				</xs:annotation>			</xs:element>			<xs: