e="xs:string">						<xs:maxLength value="8"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="mainReferenceNumber" type="customsMainReferenceNumber" minOccurs="0"/>			<xs:element name="writeOffDate" type="xs:date" minOccurs="0"/>			<xs:element name="typeDeclaration" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:length value="2"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="destinationCountry" type="country" minOccurs="0"/>			<xs:element name="amount" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:decimal">						<xs:totalDigits value="15"/>						<xs:fractionDigits value="3"/>					</xs:restriction>				</xs:simpleType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="VATChargesType">		<xs:sequence>			<xs:element name="charges">				<xs:simpleType>					<xs:restriction base="VATCharges">						<xs:totalDigits value="18"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="ExchangeRate" type="ExchangeRateType" minOccurs="0">				<xs:annotation>					<xs:documentation>Use on GoodsHeader level only.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="VATRegime" minOccurs="0">				<xs:annotation>					<xs:documentation>Vat Regime for Fiscal Representation1= Export2= Delivery EU (Levering EU)3= Inland 21% (Binnenland 21%)5= Inland Co-contractor (Binnenland - Medecontractant)</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:integer">						<xs:totalDigits value="2"/>						<xs:enumeration value="1"/>						<xs:enumeration value="2"/>						<xs:enumeration value="3"/>						<xs:enumeration value="5"/>					</xs:restriction>				</xs:simpleType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="CustomsChargesType">		<xs:sequence>			<xs:element name="transportInsuranceCharges" minOccurs="0">				<xs:annotation>					<xs:documentation>Transport + insurance Cost for Belgium CustomsOnly Transport Cost for Dutch Customs and the rest of the charges like insurance,other  will follow in the fields below</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="transportInsuranceCharges">						<xs:totalDigits value="18"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="ExchangeRate" type="ExchangeRateType" minOccurs="0">				<xs:annotation>					<xs:documentation>Exchange Rate for transportIsuranceCharges TagUse on GoodsHeader level only.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="InsuranceCharges" minOccurs="0">				<xs:annotation>					<xs:documentation>For Dutch customs only</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:sequence>						<xs:element name="insuranceCharges">							<xs:simpleType>								<xs:restriction base="transportInsuranceCharges"/>							</xs:simpleType>						</xs:element>						<xs:element name="ExchangeRate" type="ExchangeRateType" minOccurs="0">							<xs:annotation>								<xs:documentation>Exchange Rate for transportIsuranceCharges TagUse on GoodsHeader level only.</xs:documentation>							</xs:annotation>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="OtherCharges" minOccurs="0">				<xs:annotation>					<xs:documentation>For Dutch customs only</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:sequence>						<xs:element name="otherCharges">							<xs:simpleType>								<xs:restriction base="transportInsuranceCharges"/>							</xs:simpleType>						</xs:element>						<xs:element name="ExchangeRate" type="ExchangeRateType" minOccurs="0">							<xs:annotation>								<xs:documentation>Exchange Rate for transportIsuranceCharges TagUse on GoodsHeader level only.</xs:documentation>							</xs:annotation>						</xs:element>