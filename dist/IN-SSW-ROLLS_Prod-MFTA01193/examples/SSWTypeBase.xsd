s:restriction>														</xs:simpleType>													</xs:element>													<xs:element name="Valuation_Indicator_3">														<xs:annotation>															<xs:documentation>Sale or price is subject to some condition or consideration in accordance with Article 70(3)(b) of the Code.</xs:documentation>														</xs:annotation>														<xs:simpleType>															<xs:restriction base="xs:string">																<xs:enumeration value="Y"/>																<xs:enumeration value="N"/>															</xs:restriction>														</xs:simpleType>													</xs:element>													<xs:element name="Valuation_Indicator_4">														<xs:annotation>															<xs:documentation>The sale is subject to an arrangement under which part of the proceeds of any subsequent resale, disposal or use accrues directly or indirectly to the seller.</xs:documentation>														</xs:annotation>														<xs:simpleType>															<xs:restriction base="xs:string">																<xs:enumeration value="Y"/>																<xs:enumeration value="N"/>															</xs:restriction>														</xs:simpleType>													</xs:element>												</xs:sequence>											</xs:choice>										</xs:complexType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="Outbound" minOccurs="0">							<xs:annotation>								<xs:documentation>When Typedossier='O' fill in this outbound related information</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="departedDate" minOccurs="0">										<xs:annotation>											<xs:documentation>Date (YYYY-MM-DD) (Outbound Only)</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:date"/>										</xs:simpleType>									</xs:element>									<xs:element name="departedTime" minOccurs="0">										<xs:annotation>											<xs:documentation>Time (HH:MM:SS) (Outbound Only)</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:time"/>										</xs:simpleType>									</xs:element>									<xs:element name="lloydsNumber" minOccurs="0">										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:maxLength value="8"/>												<xs:pattern value="L[0-9]{7}"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="conveyanceNumber" minOccurs="0">										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:maxLength value="6"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="Consignee" minOccurs="0">										<xs:annotation>											<xs:documentation>For all outbound shipments, if the destination country is within the European Union, this is the importer.  If the import is for own account, this value is always the same.  The operatoridentity is required > See guidelince for "Bill /Sold To Party" > BOX 8 on declaration</xs:documentation>										</xs:annotation>										<xs:complexType>											<xs:complexContent>												<xs:extension base="RelationType">													<xs:sequence>														<xs:element name="SendMail" minOccurs="0">															<xs:complexType>																<xs:sequence>																	<xs:element name="sendMail" type="booleanType"/>																	<xs:element name="ContactPerson" type="RelationContactPerson"/>																</xs:sequence>															</xs:complexType>														</xs:element>													</xs:sequence>												</xs:extension>											</xs:complexContent>										</xs:complexType>									</xs:element>									<xs:element name="ConsigneeImport" minOccurs="0">										<xs:annotation>											<xs:documentation>Used for forwarders:In case the consignee for the import declaration is different as the consignee.</xs:documentation>										</xs:annotation>										<xs:complexType>											<xs:complexContent>												<xs:extension base="RelationType">													<xs:sequence>														<xs:element name="SendMail" minOccurs="0">															<xs:complexType>																<xs:sequence>																	<xs:element name="sendMail" type="booleanType"/>																	<xs:element name="ContactPerson" type="RelationContactPerson"/>																</xs:sequence>															</xs:complexType>														</xs:element>													</xs:sequence>												</xs:extension>											</xs:complexContent>										</xs:complexType>									</xs:element>									<xs:element name="ConsigneeNCTS" minOccurs="0">										<xs:annotation>											<xs:documentation>Consignee of the NCTS (the last party within the European Union to which the NCTS document is sent.</xs:documentation>										</xs:annotation>										<xs:complexType>											<xs:complexContent>												<xs:extension base="RelationType">													<xs:sequence>														<xs:element name="SendMail" minOccurs="0">															<xs:complexType>																<xs:sequence>																	<xs:element name="sendMail" type="booleanType"/>																	<xs:element name="ContactPerson" type="RelationContactPerson"/>																</xs:sequence>															</xs:complexType>														</xs:element>													</xs:sequence>												</xs:extension>											</xs:complexContent>										</xs:complexType>									</xs:element>									<xs:element name="ConsigneeEMCS" minOccurs="0">										<xs:complexType>											<xs:complexContent>												<xs:extension base="RelationType">													<xs:sequence>														<xs:element name="SendARC" minOccurs="0">															<xs:annotation>																<xs:documentation>EMCS</xs:documentation>															</xs:annotation>															<xs:complexType>																<xs:sequence>																	<xs:element name="sendMail" type="booleanType"/>																	<xs:element name="ContactPerson" type="RelationContactPerson"/>																</xs:sequence>															</xs:complexType>														</xs:element>													</xs:sequence>												</xs:extension>											</xs:complexContent>										</xs:complexType>									</xs:element>									<xs:element name="destinationCountry" type="destinationCountry"/>									<xs:element name="destinationRegion" minOccurs="0">										<xs:annotation>											<xs:documentation>if destination country = BE then 1=Vlaams Gewest, 2=Waals Gewest, 3=Brussels or do not supply when it is defaulted. Hoofdstedelijk Gewest else, request codes from Stream Software.  only used for non fiscale EU area.</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:string"/>										</xs:simpleType>									</xs:element>									<xs:element name="makeNctsT2" type="booleanType" minOccurs="0">										<xs:annotation>											<xs:documentation>Can be activated.  Is used when free goods are transported to the EU and there is need for a T2 document.</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="makePldaT2L" type="booleanType" minOccurs="0">										<xs:annotation>											<xs:documentation>Can be activated. Is used when a T2L document is required for transport</xs:documentation>										</xs:annotation>									</xs:element>									<xs:choice minOccurs="0">										<xs:element name="transitFlag" type="booleanType" minOccurs="0">											<xs:annotation>												<xs:documentation>Indicates dossier picks only transit goods and will be sent  as transit</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="clearGoods" type="booleanType" minOccurs="0">											<xs:annotation>												<xs:documentation>Goods will be cleared before shipment</xs:documentation>											</xs:annotation>										</xs:element>									</xs:choice>									<xs:element name="Scrap" minOccurs="0">										<xs:annotation>											<xs:documentation>This field can only be used when scapping under customs supervision.</xs:documentation>										</xs:annotation>										<xs:complexType>											<xs:sequence>												<xs:element name="scrap" type="booleanType" minOccurs="0">													<xs:annotation>														<xs:documentation>Must be filled in if this is a Customs Scrap dossier.  This means customs will supervise a scrapping process and create a PV.</xs:documentation>													</xs:annotation>												</xs:element>												<xs:element name="number" minOccurs="0" maxOccurs="0">													<xs:annotation>														<xs:documentation>Not supportedThe number on the document (PV) created by customs.</xs:documentation>													</xs:annotation>												</xs:element>												<xs:element name="date" minOccurs="0" maxOccurs="0">													<xs:annotation>														<xs:documentation>Not supportedThe date which is on the document of customs when it was scrapped under supervision of customs.</xs:documentation>													</xs:annotation>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="dossierDate" minOccurs="0">							<xs:annotation>								<xs:documentation>Date Dossier, writing in the administraton.(YYYY-MM-DD) </xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:date"/>							</xs:simpleType>						</xs:element>						<xs:element name="commercialReference" minOccurs="0">							<xs:complexType>								<xs:simpleContent>									<xs:extension base="xs:string">										<xs:attribute name="setEmpty" type="booleanType"/>									</xs:extension>								</xs:simpleContent>							</xs:complexType>						</xs:element>						<xs:element name="Invoice" minOccurs="0">							<xs:complexType>								<xs:sequence>									<xs:element name="invoiceNumber" minOccurs="0">										<xs:annotation>											<xs:documentation>The number of the invoice which is transmitted</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:maxLength value="35"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="invoiceDate" type="xs:date" minOccurs="0">										<xs:annotation>											<xs:documentation>Date Invoice (YYYY-MM-DD) </xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="invoiceAmount" type="invoiceAmount" minOccurs="0">										<xs:annotation>											<xs:documentation>This is a control number.  The amount must be equal to the sum of price in GoosdItem level.</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="ExchangeRate" minOccurs="0">										<xs:complexType>											<xs:complexContent>												<xs:extension base="ExchangeRateType"/>											</xs:complexContent>										</xs:complexType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="FiscalPrice" minOccurs="0">							<xs:annotation>								<xs:documentation>FiscalPrice for fiscal representation</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="fiscalPrice">										<xs:annotation>											<xs:documentation>price is the total fiscalprice.</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="price">												<xs:totalDigits value="18"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="ExchangeRate" type="ExchangeRateType" minOccurs="0">										<xs:annotation>											<xs:documentation>Deprecated: Do not use. Use on GoodsHeader level only.</xs:documentation>										</xs:annotation>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="deferredPayment" type="deferredPayment" minOccurs="0"/>						<xs:element name="expectedDate" type="xs:date" minOccurs="0">							<xs:annotation>								<xs:documentation>When the goods are expected to arrive/depart Date (YYYY-MM-DD) </xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="expectedTime" type="xs:time" minOccurs="0">							<xs:annotation>								<xs:documentation>When the goods are expected to arrive/depart Time (HH:MM:SS)</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="customsNotifyDate" type="xs:date" minOccurs="0">							<xs:annotation>								<xs:documentation>When Customs was notified in advance of the arrival/departure of the goods. Date (YYYY-MM-DD) </xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="customsNotifyTime" type="xs:time" minOccurs="0">							<xs:annotation>								<xs:documentation>When Customs was notified in advance of the arrival/departure of the goods. Time (HH:MM:SS)</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="TransactionNature" minOccurs="0">							<xs:annotation>								<xs:documentation>Usually defaulted in the System as 1-1</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="transactionNature1" type="transactionNature1"/>									<xs:element name="transactionNature2" type="transactionNature2" minOccurs="0"/>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="destinationType" minOccurs="0">							<xs:annotation>								<xs:documentation>EMCS Destination type code1= Tax Warehouse2= Registerd Consignee3=Temporary4= Direct5= Exempted6= Export8= UNKNOWN DESTINATION  (CONSIGNEE UNKNOWN)</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:minLength value="0"/>									<xs:maxLength value="1"/>									<xs:enumeration value="1"/>									<xs:enumeration value="2"/>									<xs:enumeration value="3"/>									<xs:enumeration value="4"/>									<xs:enumeration value="5"/>									<xs:enumeration value="6"/>									<xs:enumeration value="8"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="JourneyTime" minOccurs="0">							<xs:annotation>								<xs:documentation>EMCS JourneyTime</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="type">										<xs:annotation>											<xs:documentation> 'H' = hours or 'D'=day</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:maxLength value="1"/>												<xs:minLength value="1"/>												<xs:enumeration value="D"/>												<xs:enumeration value="H"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="time">										<xs:annotation>											<xs:documentation>type=H > possible values: 0-24type=D > possible values: 0-92</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:maxLength value="2"/>												<xs:minLength value="0"/>											</xs:restriction>										</xs:simpleType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="Warehouse" type="TWarehouse" minOccurs="0" maxOccurs="0">							<xs:annotation>								<xs:documentation>Customs warehouse information. Based on SAD box 49Can be defaulted based on the customs license defintionBased on customs license "entrepot Id"</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="WarehouseLocation" type="RelationType" minOccurs="0">							<xs:annotation>								<xs:documentation>Location of the warehouse.  If only 1 warehouse, defaulted in application.DossierField "Warehouse"</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="CustomProcedure" type="CustomProcedureType" minOccurs="0"/>						<xs:element name="TotalCharges" type="ChargesType" minOccurs="0"/>						<xs:element name="TotalPackaging" type="PackagingType" minOccurs="0"/>						<xs:element name="totalGrossMass" minOccurs="0">							<xs:annotation>								<xs:documentation>Total grossmass of the shipment, inclusive of packing materials for transport.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="grossMass">									<xs:totalDigits value="18"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="TransportMeans" minOccurs="0">							<xs:complexType>								<xs:sequence>									<xs:element name="DeliveryTerms" minOccurs="0">										<xs:complexType>											<xs:sequence>												<xs:element name="deliveryTerms" type="deliveryTerms" minOccurs="0">													<xs:annotation>														<xs:documentation>Used delivery terms for the customs document to be created (from invoice) Coded according to customs SAD box 20 </xs:documentation>													</xs:annotation>												</xs:element>												<xs:element name="deliveryTermsPlace" minOccurs="0">													<xs:annotation>														<xs:documentation>Place where the delivery term takes place according to customs SAD box 20</xs:documentation>													</xs:annotation>													<xs:simpleType>														<xs:restriction base="deliveryTermsPlace"/>													</xs:simpleType>												</xs:element>												<xs:element name="deliveryTermsCountryCode" type="country" minOccurs="0"/>												<xs:element name="deliveryTermsLocationCode" minOccurs="0">													<xs:simpleType>														<xs:restriction base="xs:string">															<xs:maxLength value="17"/>														</xs:restriction>													</xs:simpleType>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>									<xs:element name="borderMode" type="borderMode" minOccurs="0">										<xs:annotation>											<xs:documentation>Means of transport on the border of the EU SAD box 25</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="typeOfIdentification" minOccurs="0">										<xs:annotation>											<xs:documentation>19 08 061 000Type of identification</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:minLength value="2"/>												<xs:maxLength value="2"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="borderNationality" minOccurs="0">										<xs:annotation>											<xs:documentation>Nationality of the transportmeans on the border of the EU SAD box 21</xs:documentation>										</xs:annotation>										<xs:complexType>											<xs:simpleContent>												<xs:extension base="borderNationality">													<xs:attribute name="setEmpty" type="booleanType"/>												</xs:extension>											</xs:simpleContent>										</xs:complexType>									</xs:element>									<xs:element name="borderIdentity" minOccurs="0">										<xs:complexType>											<xs:simpleContent>												<xs:extension base="borderIdentity">													<xs:attribute name="setEmpty" type="booleanType"/>												</xs:extension>											</xs:simpleContent>										</xs:complexType>									</xs:element>									<xs:element name="inlandMode" minOccurs="0">										<xs:annotation>											<xs:documentation>Means of transport from the border to the inland. SAD box 26</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="inlandMode">												<xs:minLength value="1"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="inlandDepartureIdentity" minOccurs="0">										<xs:annotation>											<xs:documentation>Identity of the inland transportmeans arriving or departing.</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="departureIdentity">												<xs:maxLength value="27"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="inlandDepartureNationality" type="departureNationality" minOccurs="0">										<xs:annotation>											<xs:documentation>Nationality of the inland transportmeans arriving or departing.</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="transportType" minOccurs="0">										<xs:annotation>											<xs:documentation>Type of inland transportmeans arriving or departing.</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:maxLength value="2"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="dispatchCountry" type="dispatchCountry" minOccurs="0">										<xs:annotation>											<xs:documentation>Last country from which the goods were sent. SAD box 15a</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="dispatchRegion" minOccurs="0">										<xs:annotation>											<xs:documentation>Request codes from Stream Software.  only used for non fiscale EU area.</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:string"/>										</xs:simpleType>									</xs:element>									<xs:element name="dispatchLocation" minOccurs="0">										<xs:annotation>											<xs:documentation>Departure location (UN LOCODE) used for Air freight discount </xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:minLength value="5"/>												<xs:maxLength value="5"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="departureIdentity" minOccurs="0">										<xs:annotation>											<xs:documentation>Identity of the transportmeans arriving or departing.  SAD box 18</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="departureIdentity"/>										</xs:simpleType>									</xs:element>									<xs:element name="departureNationality" type="departureNationality" minOccurs="0">										<xs:annotation>											<xs:documentation>Nationality of the transportmeans arriving or departing. SAD box 18</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="loadingPlaceIdentity" type="loadingPlaceIdentity" minOccurs="0">										<xs:annotation>											<xs:documentation>Identity where the goods are loaded.</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="trailerIdentity" minOccurs="0">										<xs:annotation>											<xs:documentation>Identity of the transport trailer. </xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="departureIdentity"/>										</xs:simpleType>									</xs:element>									<xs:element name="transportArrangment" minOccurs="0">										<xs:annotation>											<xs:documentation>EMCS Transport arrangement1= Consignor2= Consignee3= Owner Of the good