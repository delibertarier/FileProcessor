ccurs="0">				<xs:annotation>					<xs:documentation>Same as UndgCode1.  Only for Luxemburg</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="cusCode" minOccurs="0">				<xs:annotation>					<xs:documentation>A CUS code from the Ecics database must be entered for the release for free circulation and (re)export of chemical substances. (18 08 001 000)</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="9"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="exciseProductCode" minOccurs="0">				<xs:annotation>					<xs:documentation>EMCS Exise ProductCode</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="4"/>						<xs:minLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="exciseCode_NL" minOccurs="0">				<xs:annotation>					<xs:documentation>Nationale Accijnscode (Netherlands)</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="2"/>						<xs:minLength value="2"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="detailedNonAlcoholicProduct" minOccurs="0">				<xs:annotation>					<xs:documentation>identification for a non alcholoic product in the Netherlands:V: FruitjuiceG: Vegetable juiceM: Mineral water</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="1"/>						<xs:enumeration value="V"/>						<xs:enumeration value="G"/>						<xs:enumeration value="M"/>						<xs:enumeration value=""/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="FiscalMark" minOccurs="0