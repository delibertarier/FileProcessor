<xs:complexType name="CommodityType">		<xs:annotation>			<xs:documentation>Type defining a Commodity</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="typeDeclaration" minOccurs="0">				<xs:annotation>					<xs:documentation>Mandatory if used in the commodities interfacePI or PE: PI is used to identify import commodity codes (10 characters).  PE is used to identify export commodity codes (8 characters).SI or SE for Saggita commoditycodes</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="2"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="commodityCode">				<xs:annotation>					<xs:documentation>Mandotory when dossierline in stead of product commodity</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="10"/>						<xs:minLength value="8"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="firstAdditionalCommodity" minOccurs="0">				<xs:simpleType>					<xs:restriction base="firstAdditionalCommodity">						<xs:minLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="secondAdditionalCommodity" minOccurs="0">				<xs:simpleType>					<xs:restriction base="secondAdditionalCommodity">						<xs:minLength value="4"/>						<xs:maxLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="nationalAdditionalCommodity1" minOccurs="0">				<xs:simpleType>					<xs:restriction base="nationalAdditionalCommodity1">						<xs:minLength value="4"/>						<xs:maxLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="nationalAdditionalCommodity2" minOccurs="0">				<xs:simpleType>					<xs:restriction base="nationalAdditionalCommodity2">						<xs:minLength value="4"/>						<xs:maxLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="nationalAdditionalCommodity3" minOccurs="0">				<xs:simpleType>					<xs:restriction base="nationalAdditionalCommodity3">						<xs:minLength value="4"/>						<xs:maxLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="exciseGroupCode" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="4"/>						<xs:minLength value="4"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="ownReference" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="customsGoodsDescription" minOccurs="0">				<xs:annotation>					<xs:documentation>Description for customs, must be in language used by customs.</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="500"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="goodsDescription_NL" minOccurs="0">				<xs:annotation>					<xs:documentation>Description in Dutch</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="500"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="goodsDescription_FR" minOccurs="0">				<xs:annotation>					<xs:documentation>Description in French</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="500"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="remarks" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="500"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="SupplementaryUnits" type="SupplementaryUnitsType" minOccurs="0" maxOccurs="0"/>			<xs:element name="VATPercentage" minOccurs="0" maxOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:decimal">						<xs:totalDigits value="5"/>						<xs:fractionDigits value="2"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:choice minOccurs="0" maxOccurs="0">				<xs:annotation>					<xs:documentation>These are the default import (3th country) duties for this speceific commodity.  any other import dutie can be supplied per country (of origin).</xs:documentation>				</xs:annotation>				<xs:element name="DefaultImportDuties" minOccurs="0">					<xs:annotation>						<xs:documentation>Defined as an ad valorem right</xs:documentation>					</xs:annotation>					<xs:simpleType>						<xs:restriction base="xs:decimal">							<xs:totalDigits value="5"/>							<xs:fractionDigits value="2"/>						</xs:restriction>					</xs:simpleType>				</xs:element>				<xs:element name="DefaultImportDutiesString" minOccurs="0">					<xs:annotation>						<xs:documentation>Can be defided as ad valorem (99.999 %) or in case of non ad valorem rights (see tarweb for notation)</xs:documentation>					</xs:annotation>					<xs:simpleType>						<xs:restriction base="xs:string">							<xs:maxLength value="512"/>						</xs:restriction>					</xs:simpleType>				</xs:element>			</xs:choice>			<xs:element name="ImportDuties" minOccurs="0" maxOccurs="0">				<xs:complexType>					<xs:sequence>						<xs:element name="ImportDuty" maxOccurs="unbounded">							<xs:complexType>								<xs:sequence>									<xs:element name="country" type="originCountry">										<xs:annotation>											<xs:documentation>There can be only one duty per country in one commodity.</xs:documentation>										</xs:annotation>									</xs:element>									<xs:choice>										<xs:annotation>											<xs:documentation>See remarks on the default importduty</xs:documentation>										</xs:annotation>										<xs:element name="duty">											<xs:simpleType>												<xs:restriction base="xs:decimal">													<xs:totalDigits value="5"/>													<xs:fractionDigits value="2"/>												</xs:restriction>											</xs:simpleType>										</xs:element>										<xs:element name="dutyString">											<xs:simpleType>												<xs:restriction base="xs:string">													<xs:maxLength value="512"/>												</xs:restriction>											</xs:simpleType>										</xs:element>									</xs:choice>									<xs:element name="preference" minOccurs="0">										<xs:complexType>											<xs:sequence>												<xs:element name="preference1">													<xs:simpleType>														<xs:restriction base="preference1">															<xs:minLength value="1"/>														</xs:restriction>													</xs:simpleType>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>									<xs:element name="PassedValidityDate" type="xs:date" minOccurs="0"/>								</xs:sequence>							</xs:complexType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="ProducedDocuments" minOccurs="0">				<xs:complexType>					<xs:sequence>						<xs:sequence>							<xs:element name="ProducedDocument" maxOccurs="unbounded">								<xs:complexType>									<xs:sequence>										<xs:element name="Document" type="TProducedDocument"/>										<xs:element name="producedDocumentsValidationOffice" minOccurs="0">											<xs:simpleType>												<xs:restriction base="ProducedDocumentsValidationOffice"/>											</xs:simpleType>										</xs:element>										<xs:element name="producedDocumentsInformationDate" type="ProducedDocumentsInformationDate" minOccurs="0"/>										<xs:element name="ArchiveInformation" type="TArchiveInformation" minOccurs="0"/>										<xs:element name="DocumentQuantity" type="TDocumentQuantity" minOccurs="0"/>										<xs:element name="complementaryInformation" minOccurs="0">											<xs:simpleType>												<xs:restriction base="complementaryInformationProduced">													<xs:maxLength value="25"/>												</xs:restriction>											</xs:simpleType>										</xs:element>										<!-- authorisationHolderCategory added under e-Globalization -->										<xs:element name="authorisationHolderCategory" type="authorisationHolderCategory" minOccurs="0"/>										<!-- authorisationHolderID added under e-Globalization -->										<xs:element name="authorisationHolderID" type="authorisationHolderID" minOccurs="0"/>										<xs:element name="country" type="originCountry" minOccurs="0"/>									</xs:sequence>								</xs:complexType>							</xs:element>						</xs:sequence>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="CalculationUnits" minOccurs="0">				<xs:annotation>					<xs:documentation>The sequence of the units is important for not having a mixup between interfaces.</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:sequence>						<xs:element name="calculationCode" minOccurs="0" maxOccurs="3">							<xs:simpleType>								<xs:restriction base="calculationCode"/>							</xs:simpleType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="ChargesType">		<xs:annotation>			<xs:documentation>Type defining a Charge</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="VATCharges" type="VATChargesType" minOccurs="0">				<xs:annotation>					<xs:documentation>Charges which are added to the Customs Value to become the VAT taxable amount.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="CustomsCharges" type="CustomsChargesType" minOccurs="0">				<xs:annotation>					<xs:documentation>This is for backward compatible => use the next tags of DV1ChargesCharges which are added to the price to become the customs value.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:sequence/>			<xs:element name="DV1Charges" minOccurs="0">				<xs:annotation>					<xs:documentation>Charges which  fall under DV1</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:sequence>						<!--Box A - Basis of Calculation  -->						<!--Box B - Costs not included in Box A-->						<!--Box C - Deductions included in Box A-->						<xs:element name="CalcBasis">							<xs:complexType>								<xs:sequence>									<!--11. b) Indirect payments- see box 8 (b)-->									<xs:element name="IndirectPayments" type="TInvoice" minOccurs="0">										<xs:annotation>											<xs:documentation>11b => AL	Indirect payments and other payments (Article 70 of the code)</xs:documentation>										</xs:annotation>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="Additions">							<xs:complexType>								<xs:sequence>									<!--13. Costs incurred by the buyer-->									<xs:element name="BuyerCosts" minOccurs="0">										<xs:complexType>											<xs:sequence>												<!--13. a) Commissions, except buying commissions-->												<xs:element name="Commissions" type="TInvoice" minOccurs="0">													<xs:annotation>														<xs:documentation>13A => AB	Commissions and brokerage, except buying commissions</xs:documentation>													</xs:annotation>												</xs:element>												<!--13. b) Brokerage-->												<xs:element name="Brokerage" type="TInvoice" minOccurs="0">													<xs:annotation>														<xs:documentation>13B => AB	Commissions and brokerage, except buying commissions</xs:documentation>													</xs:annotation>												</xs:element>												<!--13. c) Containers and packaging-->												<xs:element name="Containers" type="TInvoice" minOccurs="0">													<xs:annotation>														<xs:documentation>13C => AB	Commissions and brokerage, except buying commissions</xs:documentation>													</xs:annotation>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>									<!--14. Goods and services supplied by the buyer free of charge or at reduced cost for use in connection with the production and sale for export of the imported goods:                     The values shown represent an appotionment where appropriate-->									<xs:element name="BuyerGoodsServices" minOccurs="0">										<xs:complexType>											<xs:sequence>												<!--14. a) Value of materials, components, parts and similar items incorporated in the imported goods-->												<xs:element name="MaterialsIncorporated" type="TInvoice" minOccurs="0">													<xs:annotation>														<xs:documentation>14A => AE Materials, components, parts and similar items incorporated in the imported goods</xs:documentation>													</xs:annotation>												</xs:element>												<!--14. b) Value of tools, dies, moulds and similar items used in the production of the imported goods-->												<xs:element name="Tools" type="TInvoice" minOccurs="0">													<xs:annotation>														<xs:documentation>14B => Tools, dies, moulds and similar items used in the production of the imported goods</xs:documentation>													</xs:annotation>												</xs:element>												<!--14. c) Value of materials consumed in the production of the imported goods-->												<xs:element name="MaterialsConsumed" type="TInvoice" minOccurs="0">													<xs:annotation>														<xs:documentation>14C => AG Materials consumed in the production of the imported goods </xs:documentation>													</xs:annotation>												</xs:element>												<!--14. d) Value of engineering, development, artwork, design work and plans and sketches undertaken elsewhere than in the Community and necessary for the production of the imported goods-->												<xs:element name="Engineering" type="TInvoice" minOccurs="0">													<xs:annotation>														<xs:documentation>14D => AH Engineering, development, artwork, design work and plans and sketches undertaken elsewhere than in the European Union and necessary for the production of the imported goods</xs:documentation>													</xs:annotation>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>									<!-- <xs:annotation>                <xs:documentation>Box 15 - Royalties, license fees- see box 9 a)</xs:documentation>            </xs:annotation> -->									<!--15. Royalties, license fees- see box 9 a)-->									<xs:element name="Royalties" type="TInvoice" minOccurs="0">										<xs:annotation>											<xs:documentation>15 => AI Royalties and license fees</xs:documentation>										</xs:annotation>									</xs:element>									<!-- <xs:annotation>                <xs:documentation>Box 16 - Proceeds or any subsequent resale, disposal or use accruing to the seller- see box 9 b)</xs:documentation>            </xs:annotation> -->									<!--16. Proceeds or any subsequent resale, disposal or use accruing to the seller- see box 9 b)-->									<xs:element name="Proceeds" type="TInvoice" minOccurs="0">										<xs:annotation>											<xs:documentation>16 => AJ Proceeds of any subsequent resale, disposal or use accruing to the seller</xs:documentation>										</xs:annotation>									</xs:element>									<!--17. Costs of delivery to (place of introduction)-->									<xs:element name="DeliveryCost" minOccurs="0">										<xs:complexType>											<xs:sequence>												<!--17. Place of introduction-->												<xs:element name="placeOfIntro" type="place" minOccurs="0"/>												<!--17 a) Costs of the transport-->												<xs:element name="Transport" type="TInvoice" minOccurs="0">													<xs:annotation>														<xs:documentation>17A => AK	Transport costs, loading and handling charges and insurance costs up to the place of introduction in the European Union</xs:documentation>													</xs:annotation>												</xs:element>												<!--17 b) Loading and handling of charges-->												<xs:element name="LoadingAndHandling" type="TInvoice" minOccurs="0">													<xs:annotation>														<xs:documentation>17B => AK	Transport costs, loading and handling charges and insurance costs up to the place of introduction in the European Union</xs:documentation>													</xs:annotation>												</xs:element>												<!--17 c) Insurance costs-->												<xs:element name="Insurance" type="TInvoice" minOccurs="0">													<xs:annotation>														<xs:documentation>17C => AK	Transport costs, loading and handling charges and insurance costs up to the place of introduction in the European Union</xs:documentation>													</xs:annotation>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>									<xs:element name="Article71" type="TInvoice" minOccurs="0">										<xs:annotation>											<xs:documentation>Introduced in Eucdm:AN	Additions based on a decision granted in accordance with Article 71 of Delegated Regulation (EU) 2015/2446</xs:documentation>										</xs:annotation>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="Deductions">							<xs:complexType>								<xs:sequence>									<xs:annotation>										<xs:documentation>Box 19 - Costs of transport after arrival at place of introduction</xs:documentation>									</xs:annotation>									<!--19. Costs of transport after arrival at place of introduction-->									<xs:element name="TransportAfterArrival" type="TInvoice" minOccurs="0">										<xs:annotation>											<xs:documentation>19 => BA Costs of transport after arrival at the place of introduction</xs:documentation>										</xs:annotation>									</xs:element>									<!-- <xs:annotation>                <xs:documentation>Box 20 - Charges for construction, erection, assembly, maintenance or technical assistance undertaken after importation</xs:documentation>            </xs:annotation> -->									<!--20. Charges for construction, erection, assembly, maintenance or technical assistance undertaken after importation.-->									<xs:element name="ChargesAfterImport" type="TInvoice" minOccurs="0">										<xs:annotation>											<xs:documentation>20 => BB Charges for construction, erection, assembly, maintenance or technical assistance undertaken after importation</xs:documentation>										</xs:annotation>									</xs:element>									<!--21. Other charges(specify) -->									<xs:element name="OtherCharges" type="TOtherCharges" minOccurs="0">										<xs:annotation>											<xs:documentation>21 => BC Import duties or other charges payable in the Union for reason of the import or sale of goods</xs:documentation>										</xs:annotation>									</xs:element>									<!-- <xs:annotation>                <xs:documentation>Box 22 - Customs duties and taxes payable in the Community by reason of the importation or sale of the goods</xs:documentation>            </xs:annotation> -->									<!--22. Customs duties and taxes payable in the Community by reason of the importation or sale of the goods-->									<xs:element name="ImportDutiesAndTaxes" type="TInvoice" minOccurs="0">										<xs:annotation>											<xs:documentation>22 => BC  Import duties or other charges payable in the Union for reason of the import or sale of goods</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="InterestCharges" minOccurs="0">										<xs:annotation>											<xs:documentation>Introduced in EUCDM:BD	Interest charges</xs:documentation>										</xs:annotation>										<xs:complexType>											<xs:sequence>												<!--21. Other charges -->												<!--21. Details of other charges-->												<xs:sequence>													<xs:element name="ExchangeRate" type="TExchangeRate"/>													<xs:element name="invoiceAmount" type="invoiceAmount"/>												</xs:sequence>											</xs:sequence>										</xs:complexType>									</xs:element>									<xs:element name="ReproduceCharges" minOccurs="0">										<xs:annotation>											<xs:documentation>Introduced in EUCDM:BE	Charges for the right to reproduce the imported goods in the European Union</xs:documentation>										</xs:annotation>										<xs:complexType>											<xs:sequence>												<!--21. Other charges -->												<!--21. Details of other charges-->												<xs:sequence>													<xs:element name="ExchangeRate" type="TExchangeRate"/>													<xs:element name="invoiceAmount" type="invoiceAmount"/>												</xs:sequence>											</xs:sequence>										</xs:complexType>									</xs:element>									<xs:element name="BuyingCommissions" minOccurs="0">										<xs:annotation>											<xs:documentation>Introduced in EUCDM:BF Buying commissions</xs:documentation>										</xs:annotation>										<xs:complexType>											<xs:sequence>												<!--21. Other charges -->												<!--21. Details of other charges-->												<xs:sequence>													<xs:element name="ExchangeRate" type="TExchangeRate"/>													<xs:element name="invoiceAmount" type="invoiceAmount"/>												</xs:sequence>											</xs:sequence>										</xs:complexType>									</xs:element>									<xs:element name="Article71" minOccurs="0">										<xs:annotation>											<xs:documentation>Introduced in EUCDM:BG Deductions based on a decision granted in accordance with Article 71 of Delegated Regulation (EU) 2015/2446</xs:documentation>										</xs:annotation>										<xs:complexType>											<xs:sequence>												<!--21. Other charges -->												<!--21. Details of other charges-->												<xs:sequence>													<xs:element name="ExchangeRate" type="TExchangeRate"/>													<xs:element name="invoiceAmount" type="invoiceAmount"/>												</xs:sequence>											</xs:sequence>										</xs:complexType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="CustomProcedureType">		<xs:sequence>			<xs:element name="customProcedure" type="customProcedureType" minOccurs="0">				<xs:annotation>					<xs:documentation>Defines the requested customs procedure: 1 Home use, 2:Bonded Warehouse, 3:Inward Processing Relief, 4: Outward Processing Relief  (Not used)</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="customLicensing">				<xs:annotation>					<xs:documentation>Mutally agreed code between systems.  Defines which customs license will be used for these goods.</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="CutOverType">		<xs:sequence>			<xs:element name="MrnRef" minOccurs="0">				<xs:complexType>					<xs:sequence>						<xs:element name="mrn">							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="validityDateMrn" type="TDate"/>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="ImportDuty" minOccurs="0">				<xs:complexType>					<xs:sequence>						<xs:element name="importDutyAmount" type="price">							<xs:annotation>								<xs:documentation>Amount of customs duties for the tax specification ex: Is listed on an information sheet INF </xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="importDutyPct" type="percentageType" minOccurs="0"/>					</xs:sequence>				</xs:complexType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="ExchangeRateType">		<xs:annotation>			<xs:documentation>Type defining an exchange rate</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="exchangeRate" minOccurs="0">				<xs:annotation>					<xs:documentation>Must always be the customs validated exchange rate and not the commercially used exchange rate.  In general customs exchange rates are managed from within the system manually and this field must not be transmitted.</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="exchangeRate">						<xs:totalDigits value="11"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="exchangeDate" type="exchangeDate" minOccurs="0">				<xs:annotation>					<xs:documentation>Same rules applie as the ones for exchangeRate.  Do not use unless otherwise instructed (YYYY-MM-DD)</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="currency" type="currency">				<xs:annotation>					<xs:documentation>The used currency depending on its context (for example if in an invoice tag, the currency of the invoice)</xs:documentation>				</xs:annotation>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="ExternalIdentifierType">		<xs:sequence>			<xs:element name="order">				<xs:annotation>					<xs:documentation>The order in which the unique product code must be  created/found.  Put user friendly or common used codes first (nr5 = BU)</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:decimal">						<xs:totalDigits value="9"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="name">				<xs:annotation>					<xs:documentation>The name of the identifier.</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="value">				<xs:annotation>					<xs:documentation>The value for the identifier on this level.</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="ItemsType">		<xs:sequence>			<xs:element name="itemNumber" type="xs:string">				<xs:annotation>					<xs:documentation>Productcode of the item of which the B(ill) O(f) M(aterial) is composed.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="quantity" type="xs:decimal">				<xs:annotation>					<xs:documentation>The amount of stock items of the product which should be used to compose the material.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="quantityCode" minOccurs="0">				<xs:annotation>					<xs:documentation>The qualifier which defines how the stock is kept in the system.  PCE for pieces. PKG for packages. NTW for nettmass.</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="4"/>						<xs:enumeration value="PCE"/>						<xs:enumeration value="NTW"/>						<xs:enumeration value="PKG"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="customLicensing" minOccurs="0">				<xs:annotation>					<xs:documentation>Mutally agreed code between systems.  Defines which customs license will be used for these goods. (if filled)</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="stockType" type="stockTypeType" minOccurs="0">				<xs:annotation>					<xs:documentation>The type of stock which is used:  FREE for useage of free goods.  BONDED for useage of bonded goods. IPR for usage for Inwarding Processing relief goods</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="additionalRangeField1" type="externalReferenceType" minOccurs="0">				<xs:annotation>					<xs:documentation>The range in which the product should be found.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="serialnumber" minOccurs="0">				<xs:annotation>					<xs:documentation>Only supply if customs serialnumbers are REQUIRED by customs.  Also known as Chassisnumbers.</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="storageLocation" minOccurs="0">				<xs:annotation>					<xs:documentation>Only supply if product is kept on a specific location</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="16"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="StockPrincipal" type="RelationType" minOccurs="0">				<xs:annotation>					<xs:documentation>The current owner of the goods specified in the dossierlines of the incoming goods dossier.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="InboundPrincipal" type="RelationType" minOccurs="0">				<xs:annotation>					<xs:documentation>The original owner of the goods which was supplied when the goods arrived (principal of the inbound dossier).</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="originCountry" type="originCountry" minOccurs="0">				<xs:annotation>					<xs:documentation>The country of origin of which the goods are produced.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="inboundHeaderLinkID" type="externalReferenceType" minOccurs="0">				<xs:annotation>					<xs:documentation>The Link id from the dossier which should be picked.</xs:documentation>				</xs:annotation>			</xs:element>			<xs:sequence>				<xs:element name="bomUniqueReference" minOccurs="0">					<xs:annotation>						<xs:documentation>OPR: if the item is a composition of more items.</xs:documentation>					</xs:annotation>					<xs:simpleType>						<xs:restriction base="xs:string">							<xs:maxLength value="35"/>						</xs:restriction>					</xs:simpleType>				</xs:element>				<xs:element name="price" type="price" minOccurs="0">					<xs:annotation>						<xs:documentation>OPR: the price for this amount of stock</xs:documentation>					</xs:annotation>				</xs:element>				<xs:element name="addedOnLocation" minOccurs="0">					<xs:annotation>						<xs:documentation>OPR: if the item is added on location. Deliverd directly to the prodcutionfactory</xs:documentation>					</xs:annotation>					<xs:simpleType>						<xs:restriction base="xs:string">							<xs:enumeration value="T"/>							<xs:enumeration value="F"/>							<xs:enumeration value=" "/>						</xs:restriction>					</xs:simpleType>				</xs:element>				<xs:element name="useMasterCommodity" minOccurs="0">					<xs:annotation>						<xs:documentation>Special field used for reportingCan only be used in  nestedBom</xs:documentation>					</xs:annotation>					<xs:simpleType>						<xs:restriction base="xs:string">							<xs:enumeration value="T"/>							<xs:enumeration value="F"/>							<xs:enumeration value=" "/>						</xs:restriction>					</xs:simpleType>				</xs:element>				<xs:element name="composition" minOccurs="0">					<xs:annotation>						<xs:documentation>composition of the product</xs:documentation>					</xs:annotation>					<xs:simpleType>						<xs:restriction base="xs:string">							<xs:maxLength value="256"/>						</xs:restriction>					</xs:simpleType>				</xs:element>				<xs:element name="cumulationComposition" minOccurs="0">					<xs:annotation>						<xs:documentation>string where the cumulation apllied with</xs:documentation>					</xs:annotation>					<xs:simpleType>						<xs:restriction base="xs:string">							<xs:maxLength value="256"/>						</xs:restriction>					</xs:simpleType>				</xs:element>				<xs:element name="EurMedListings" minOccurs="0">					<xs:annotation>						<xs:documentation>splitted string for the cumulation composition</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:sequence>							<xs:element name="EurMedListing" maxOccurs="unbounded">								<xs:complexType>									<xs:sequence>										<xs:element name="country" type="originCountry">											<xs:annotation>												<xs:documentation>country code</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="typeOfCountry">											<xs:annotation>												<xs:documentation>Origincountry or Cumulated country</xs:documentation>											</xs:annotation>											<xs:simpleType>												<xs:restriction base="xs:string">													<xs:enumeration value="C"/>													<xs:enumeration value="O"/>												</xs:restriction>											</xs:simpleType>										</xs:element>									</xs:sequence>								</xs:complexType>							</xs:element>						</xs:sequence>					</xs:complexType>				</xs:element>				<xs:element name="cuttingOrder" minOccurs="0">					<xs:annotation>						<xs:documentation>reference</xs:documentation>					</xs:annotation>					<xs:simpleType>						<xs:restriction base="xs:string">							<xs:maxLength value="35"/>						</xs:restriction>					</xs:simpleType>				</xs:element>				<xs:element name="netMass" minOccurs="0">					<xs:annotation>						<xs:documentation>Nettmass of all stock items on this line.</xs:documentation>					</xs:annotation>					<xs:simpleType>						<xs:restriction base="netMass">							<xs:totalDigits value="18"/>						</xs:restriction>					</xs:simpleType>				</xs:element>				<xs:element name="grossMass" minOccurs="0">					<xs:annotation>						<xs:documentation>Grossmass of all stock items on this line</xs:documentation>					</xs:annotation>					<xs:simpleType>						<xs:restriction base="grossMass">							<xs:totalDigits value="18"/>						</xs:restriction>					</xs:simpleType>				</xs:element>				<xs:element name="density" type="xs:decimal" minOccurs="0">					<xs:annotation>						<xs:documentation>Density of all stock items on this line</xs:documentation>					</xs:annotation>				</xs:element>				<xs:element name="singleOrderTotal" minOccurs="0">					<xs:simpleType>						<xs:restriction base="xs:decimal">							<xs:totalDigits value="18"/>							<xs:fractionDigits value="6"/>						</xs:restriction>					</xs:simpleType>				</xs:element>			</xs:sequence>		</xs:sequence>	</xs:complexType>	<xs:complexType name="PackagingType">		<xs:sequence>			<xs:element name="marksNumber" minOccurs="0">				<xs:annotation>					<xs:documentation>Identification which is visually on the package.  This is necessary for physical verification of the package.  Customs must know in a warehouse a specific declaration references to specific packages.  This will be used for physical verification.  When goods are packaged together the same marksNumber must be used for the bypacking of the packages.</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="marksNumber"/>				</xs:simpleType>			</xs:element>			<xs:choice minOccurs="0">				<xs:element name="packages" minOccurs="0">					<xs:annotation>						<xs:documentation>Total number of packages on this line.  if any package is used twice (on the same line) it can only be counted on the first line.</xs:documentation>					</xs:annotation>					<xs:simpleType>						<xs:restriction base="xs:decimal">							<xs:totalDigits value="9"/>							<xs:fractionDigits value="0"/>						</xs:restriction>					</xs:simpleType>				</xs:element>				<xs:element name="PackagesCollection" minOccurs="0">					<xs:annotation>						<xs:documentation>Collection of packages. The total of packages will be autocalculated from this data.</xs:documentation>					</xs:annotation>					<xs:complexType>						<xs:sequence>							<xs:element name="Package" maxOccurs="unbounded">								<xs:complexType>									<xs:sequence>										<xs:element name="identifier">											<xs:annotation>												<xs:documentation>Collinumber of the package</xs:documentation>											</xs:annotation>											<xs:simpleType>												<xs:restriction base="xs:string">													<xs:maxLength value="35"/>												</xs:restriction>											</xs:simpleType>										</xs:element>										<xs:element name="type" type="packageType" minOccurs="0">											<xs:annotation>												<xs:documentation>The customs type of package.</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="ValueDetails" minOccurs="0">											<xs:complexType>												<xs:sequence>													<xs:element name="value" type="price">														<xs:annotation>															<xs:documentation>The value of the packaging material.</xs:documentation>														</xs:annotation>													</xs:element>													<xs:element name="currency" type="currency">														<xs:annotation>															<xs:documentation>The currency in which the value of the packagingmaterial is specified.</xs:documentation>														</xs:annotation>													</xs:element>												</xs:sequence>											</xs:complexType>										</xs:element>										<xs:element name="amountOfPieces">											<xs:annotation>												<xs:documentation>Amount of pieces in the package according to the specified level.  If on