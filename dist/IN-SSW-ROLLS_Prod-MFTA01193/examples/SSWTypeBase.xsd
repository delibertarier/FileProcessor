DocumentQuantity" minOccurs="0"/>									<xs:element name="complementaryInformation" minOccurs="0">										<xs:simpleType>											<xs:restriction base="complementaryInformationProduced">												<xs:maxLength value="25"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="destinationCountry" minOccurs="0"/>									<xs:element name="originCountry" minOccurs="0"/>									<xs:element name="procedurePart1" type="procedurePart1" minOccurs="0"/>									<xs:element name="procedurePart2" type="procedurePart2" minOccurs="0"/>								</xs:sequence>							</xs:complexType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="RelationContactPerson">		<xs:annotation>			<xs:documentation>Contact person of a relation</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="contactPersonCode" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="contactPersonName" minOccurs="0">				<xs:annotation>					<xs:documentation>If no contactPersonCode is provided, the code will be generated based on the contactPersonName</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="contactPersonCommunicationNumber" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="15"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="contactPersonEmail">				<xs:annotation>					<xs:documentation>In case of an emaillist, seperate with comma</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="1000"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="contactPersonCC" minOccurs="0">				<xs:annotation>					<xs:documentation>In case of an emaillist, seperate with comma</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="1000"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="contactPersonBCC" minOccurs="0">				<xs:annotation>					<xs:documentation>In case of an emaillist, seperate with comma</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="1000"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="contactPersonFaxNumber" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="15"/>					</xs:restriction>				</xs:simpleType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="RelationType">		<xs:annotation>			<xs:documentation>Type Defining a Relation</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="OperatorIdentity" minOccurs="0" maxOccurs="2">				<xs:annotation>					<xs:documentation>For Exportation of goods a EORI (005) number is necessary.  For importation of goods in Belgium a KBO (000) is necessary.  For importation of goods in EU a BIS (003) is necessary.  You can supply 2 operatoridenties for a relation. 1 should be the EORI and the other should be the KBO or BIS number.  A BIS number is the VAT number of the European country which is not Belgium.</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:sequence>						<xs:element name="country" type="country">							<xs:annotation>								<xs:documentation>Operator country where the identifier applies.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="identifier">							<xs:annotation>								<xs:documentation>Identifier for the operator.  000 = KBO, 001=REG, 002=TIN, 003=BIS, 005=EORI, 006=EORI No Check 998=Unknown VAT, 999=No VAT yet</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="operatorIdentifier">									<xs:minLength value="3"/>									<xs:maxLength value="3"/>									<xs:enumeration value="000"/>									<xs:enumeration value="001"/>									<xs:enumeration value="002"/>									<xs:enumeration value="003"/>									<xs:enumeration value="005"/>									<xs:enumeration value="006"/>									<xs:enumeration value="999"/>									<xs:enumeration value="998"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="operatorIdentity">							<xs:annotation>								<xs:documentation>Identification example for KBO = 462405532</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="operatorIdentity">									<xs:maxLength value="30"/>									<xs:minLength value="1"/>								</xs:restriction>							</xs:simpleType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="Operator" minOccurs="0">				<xs:annotation>					<xs:documentation>Required if the relation is not known in the system yet.</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:sequence>						<xs:element name="operatorName">							<xs:simpleType>								<xs:restriction base="operatorName">									<xs:minLength value="1"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="operatorName2" type="operatorName" minOccurs="0"/>						<xs:element name="OperatorAddress">							<xs:complexType>								<xs:sequence>									<xs:element name="postalCode" minOccurs="0">										<xs:simpleType>											<xs:restriction base="postalCode">												<xs:minLength value="1"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="streetAndNumber1">										<xs:simpleType>											<xs:restriction base="streetAndNumber1">												<xs:minLength value="1"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="streetAndNumber2" minOccurs="0">										<xs:simpleType>											<xs:restriction base="streetAndNumber1">												<xs:minLength value="1"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="streetAndNumber3" minOccurs="0">										<xs:simpleType>											<xs:restriction base="streetAndNumber1">												<xs:minLength value="1"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="streetAndNumber4" minOccurs="0">										<xs:simpleType>											<xs:restriction base="streetAndNumber1">												<xs:minLength value="1"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="streetAndNumber5" minOccurs="0">										<xs:simpleType>											<xs:restriction base="streetAndNumber1">												<xs:minLength value="1"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="city">										<xs:simpleType>											<xs:restriction base="city">												<xs:minLength value="1"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="country" type="country"/>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="language" type="country" minOccurs="0">							<xs:annotation>								<xs:documentation>Language</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="legalForm" minOccurs="0">							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="6"/>									<xs:minLength value="0"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="exciseNumber" minOccurs="0">							<xs:annotation>								<xs:documentation>EMCS Excise Number</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:minLength value="13"/>									<xs:maxLength value="16"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="exciseOfficeEMCS" type="departureOffice" minOccurs="0">							<xs:annotation>								<xs:documentation>EMCS Excise Office </xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="licenseStatusAC4" minOccurs="0">							<xs:annotation>								<xs:documentation>Consignee License Status for AC4 </xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:minLength value="1"/>									<xs:maxLength value="1"/>									<xs:enumeration value="0"/>									<xs:enumeration value="1"/>									<xs:enumeration value="2"/>									<xs:enumeration value="3"/>									<xs:enumeration value="4"/>									<xs:enumeration value="5"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="licenseNumberAC4" minOccurs="0">							<xs:annotation>								<xs:documentation>Consignee License Number for AC4 </xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:minLength value="1"/>									<xs:maxLength value="20"/>								</xs:restriction>							</xs:simpleType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="id" minOccurs="0">				<xs:annotation>					<xs:documentation>Customs Streamliner Relation Id</xs:documentation>				</xs:annotation>				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="10"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="erpId">				<xs:annotation>					<xs:documentation>Customs Streamliner ERP Relation Id This is the crossreference code between ERP and Streamliner Relation Masterdata. Be aware this unique over all types of relationcodes. </xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:simpleContent>						<xs:extension base="xs:string">							<xs:attribute name="setEmpty" type="booleanType"/>						</xs:extension>					</xs:simpleContent>				</xs:complexType>			</xs:element>			<xs:element name="erpId2" minOccurs="0">				<xs:simpleType>					<xs:restriction base="xs:string">						<xs:maxLength value="35"/>					</xs:restriction>				</xs:simpleType>			</xs:element>			<xs:element name="group" minOccurs="0">				<xs:annotation>					<xs:documentation>This will add the relation in a group that is only visible for a active company of BU where the group was specified. This is only to have a selected view</xs:documentation>				</xs:annotation>			</xs:element>			<xs:element name="VariableFields" minOccurs="0">				<xs:annotation>					<xs:documentation>Fields defined by the customer.The combination of Template and field may not be longer than 25 characters.A mergetag will be build on this based on VAR_template_field.This can't be used for principals in ILS.</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:complexContent>						<xs:extension base="VariableFields"/>					</xs:complexContent>				</xs:complexType>			</xs:element>			<xs:element name="Permissions" type="Permissions" minOccurs="0"/>			<xs:element name="RepresentedBy" minOccurs="0">				<xs:annotation>					<xs:documentation>This is only applicable for Customs relations (e.g. Princiapal RepresentedBy can't be used when there is an active link between the Customs Streamliner and the ILS Streamliner).</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:sequence>						<xs:element name="vatImportRelationErpId" minOccurs="0">							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="vatExportRelationErpId" minOccurs="0">							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="PdClient" minOccurs="0">				<xs:annotation>					<xs:documentation>Only Customs</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:sequence minOccurs="0">						<xs:element name="importInspectionLocationPDClient" minOccurs="0">							<xs:annotation>								<xs:documentation>Only Customs for Pd Import</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:length value="7"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="exportInspectionLocationPDClient" minOccurs="0">							<xs:annotation>								<xs:documentation>Only Customs for Pd Export</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:length value="8"/>								</xs:restriction>							</xs:simpleType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="Ncts" minOccurs="0">				<xs:complexType>					<xs:sequence minOccurs="0">						<xs:element name="Arrival" minOccurs="0">							<xs:annotation>								<xs:documentation>Used on the WarehouseRelation to default the location of the goods in NCTS Arrival</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="locationQualifier">										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:enumeration value="AGREED"/>												<xs:enumeration value="AUTHORISED"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="goodsLocation">										<xs:simpleType>											<xs:restriction base="agreedLocation"/>										</xs:simpleType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="Departure" minOccurs="0">							<xs:annotation>								<xs:documentation>Used on the WarehouseRelation to default the location of the goods in NCTS Departure</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="locationQualifier">										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:enumeration value="AGREED"/>												<xs:enumeration value="AUTHORISED"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="goodsLocation">										<xs:simpleType>											<xs:restriction base="agreedLocation"/>										</xs:simpleType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="Ags" minOccurs="0">				<xs:complexType>					<xs:sequence minOccurs="0">						<xs:element name="goodsLocation">							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="GoodsLocation" minOccurs="0">				<xs:annotation>					<xs:documentation>EUC goodslocation</xs:documentation>				</xs:annotation>				<xs:complexType>					<xs:sequence>						<xs:element name="goodsLocationCode">							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="16"/>								</xs:restriction>							</xs:simpleType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>		</xs:sequence>	</xs:complexType>	<xs:complexType name="SADDossierType">		<xs:annotation>			<xs:documentation>Type defining an SADDossier</xs:documentation>		</xs:annotation>		<xs:sequence>			<xs:element name="MessageDetails" minOccurs="0">				<xs:complexType>					<xs:sequence>						<xs:element name="transactionID" minOccurs="0" maxOccurs="0">							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="id" minOccurs="0" maxOccurs="0">							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="date" type="xs:date" minOccurs="0" maxOccurs="0"/>						<xs:element name="userID" minOccurs="0" maxOccurs="0">							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="type" minOccurs="0">							<xs:annotation>								<xs:documentation>Free to use field to identitfiy the type of interface. Some of the types has build in logic.- empty = actual/normal- INITIAL = initial stockupload- ADJUSTMENT = positive and negative adjustments- EXPECTED = expected quantities- SCRAP = scrap goods- ANNULATION = If this type contains ANNULATION the dossier- MUTATION = mutation dossier - RECREATE = the dossier and all dossierlines,docs,... are removed before processing the dossier- RECREATELINES = this will keep the dossierheader and remove all dossierlines,docs,... before processing the dossier- ACTUALRECEIVED = this will overwrite the dossier in any status and put it back in CREATE, as long as it's not in an entrepot closure.- ACTUALRECREATE = This will delete the declarations, put the dossierd back in CREATE and removes all dossierlines before processing the interface, as long as it's not in an entrepot closure. - Other values that are in use= SCRAPRETURNREQUESTMUTATIONRELEASECONFIRMATONNORMALON QUAYDECLAREOKRETURNMESSAGECHECKEDCONFIRMAUTO_OUTB_FVDECLAREINB_BODOUTB_BODOUTBOUNDSTOCKUPLOADREQUESTCHECKSAPIRESPONSEUPDATE</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="ExternalReferences" minOccurs="0">							<xs:complexType>								<xs:sequence>									<xs:element name="reference1">										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:maxLength value="35"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="reference2" minOccurs="0">										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:maxLength value="35"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="reference3" minOccurs="0">										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:maxLength value="35"/>											</xs:restriction>										</xs:simpleType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="GoodsDeclaration">				<xs:complexType>					<xs:sequence>						<xs:element name="type">							<xs:annotation>								<xs:documentation>Possible Values (I Inbound, O Outbound,L Logbook)</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="1"/>									<xs:minLength value="1"/>									<xs:enumeration value="I"/>									<xs:enumeration value="O"/>									<xs:enumeration value="L"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="linkId" minOccurs="0">							<xs:annotation>								<xs:documentation>Used when there needs to be a 1-1 relation on header level.  If updates are sent later.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="forceUpdateHeader" type="booleanType" minOccurs="0">							<xs:annotation>								<xs:documentation>Defines if zero/blank values should be considered on purpose (T/F). Deletes the entire Header and creates new header with the new data.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="overrulePickWeights" type="booleanType" minOccurs="0">							<xs:annotation>								<xs:documentation>Overrules the Pick Inbound Weights Module (T/F).If the module is active and this field = 'T', the system will act as if the module is not active.If the module is not active and this field = 'T', the system will act as if the module is active.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="Inbound" minOccurs="0">							<xs:annotation>								<xs:documentation>When Typedossier='I' fill in this inbound related information</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="Mutation" minOccurs="0">										<xs:annotation>											<xs:documentation>Following field on the header are also required for mutation: Inbound\arrivedStockType, Inbound\stocktype, CustomProcedure\customLicensing</xs:documentation>										</xs:annotation>										<xs:complexType>											<xs:sequence>												<xs:element name="isMutation" type="booleanType">													<xs:annotation>														<xs:documentation>Defines if the dossier is a mutation (T/F)</xs:documentation>													</xs:annotation>												</xs:element>												<xs:element name="mutateFromLicense" type="customsLicense">													<xs:annotation>														<xs:documentation>License from where the goods will be picked to Mutate</xs:documentation>													</xs:annotation>												</xs:element>												<xs:element name="mutateFromStorageLocation" type="storageLocation" minOccurs="0">													<xs:annotation>														<xs:documentation>If on outbound a special range of inbound must be specified, this field can be used for it.</xs:documentation>													</xs:annotation>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>									<xs:choice>										<xs:element name="immediateClearance" type="booleanType" minOccurs="0" maxOccurs="0">											<xs:annotation>												<xs:documentation>True means the goods must be cleared on arrival of the warehouse.If true then stocktype must be FREE. Please ignore and use arrivedStockType instead.</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="arrivedStockType" type="stockTypeType" minOccurs="0">											<xs:annotation>												<xs:documentation>Type of stock which arrives at the warehouse. FREE, BONDED, VATWAREHOUSE, IPR</xs:documentation>											</xs:annotation>										</xs:element>									</xs:choice>									<xs:element name="stockType" type="stockTypeType" minOccurs="0">										<xs:annotation>											<xs:documentation>The type of stock which goes in to the warehouse.  Possible Values (FREE, BONDED,IPR, VATWAREHOUSE).</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="arrivedDate" type="xs:date" minOccurs="0">										<xs:annotation>											<xs:documentation>Actual date when the goods arrive at the location.  If this is not the actual date, but the expected arrival date, use Expected Date instead.  This date will be used for arrival register.  (YYYY-MM-DD)<