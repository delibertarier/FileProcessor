xtension>								</xs:simpleContent>							</xs:complexType>						</xs:element>						<xs:element name="overview4" minOccurs="0">							<xs:annotation>								<xs:documentation>Overview fields can contain references for the user to search the document in the overview screen.  Only Uppercase (will be converted when importing).</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:simpleContent>									<xs:extension base="xs:string">										<xs:attribute name="setEmpty" type="booleanType"/>									</xs:extension>								</xs:simpleContent>							</xs:complexType>						</xs:element>						<xs:element name="overview5" minOccurs="0">							<xs:annotation>								<xs:documentation>Overview fields can contain references for the user to search the document in the overview screen.  Only Uppercase (will be converted when importing).</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:simpleContent>									<xs:extension base="xs:string">										<xs:attribute name="setEmpty" type="booleanType"/>									</xs:extension>								</xs:simpleContent>							</xs:complexType>						</xs:element>						<xs:element name="shipmentNumber" minOccurs="0">							<xs:annotation>								<xs:documentation>Number that is used to group different invoices to 1 declaration in the the multideclaration</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="businessUnit" minOccurs="0">							<xs:annotation>								<xs:documentation>Defines a unit of business within an Active Company.  Needs special setup.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="16"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="additionalScenarioSmartDeclare" minOccurs="0">							<xs:annotation>								<xs:documentation>MUTUAL agreed value.To use predefined declaration decisionsscenario.</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:simpleContent>									<xs:extension base="xs:string">										<xs:attribute name="setEmpty" type="booleanType"/>									</xs:extension>								</xs:simpleContent>							</xs:complexType>						</xs:element>						<xs:element name="autoProcess" type="booleanType" minOccurs="0">							<xs:annotation>								<xs:documentation>Type interface != L (Dossier) : not present = use config in scenario setup -> autodeclareTrue = override config in scenario -> autodeclare = trueFalse = override config in scenario -> autodeclare = falseType interface = L (Logbook ): not present  use for input/output materialTrue : close production order</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="VariableFields" minOccurs="0">							<xs:annotation>								<xs:documentation>Fields defined by the customerThe combination of Template and field may not be longer than 25 charactersA megetag will be build on this based on VAR_template_field</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:complexContent>									<xs:extension base="VariableFields"/>								</xs:complexContent>							</xs:complexType>						</xs:element>						<xs:element name="AdditionalDocuments" minOccurs="0">							<xs:annotation>								<xs:documentation>Customer defined documents can be transmitted here</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="AdditionalDocument" maxOccurs="unbounded">										<xs:complexType>											<xs:sequence>												<xs:element name="documentType">													<xs:simpleType>														<xs:restriction base="xs:string">															<xs:maxLength value="35"/>														</xs:restriction>													</xs:simpleType>												</xs:element>												<xs:element name="reference">													<xs:simpleType>														<xs:restriction base="xs:string">															<xs:maxLength value="35"/>														</xs:restriction>													</xs:simpleType>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="BatchReportLines" type="BatchReportLinesType" minOccurs="0">							<xs:annotation>								<xs:documentation>Lines which are returned from the system with messages from picking results for example.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="invoicingReference" minOccurs="0">							<xs:annotation>								<xs:documentation>Used internally.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="manipulationNumber" minOccurs="0">							<xs:annotation>								<xs:documentation>unique manipulation number for the GPA. Required in the inbound and outbound interface.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:integer">									<xs:totalDigits value="8"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="manipulationDescription" minOccurs="0">							<xs:annotation>								<xs:documentation>Description for the manipulation number.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="500"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="manipulationFromSystem" minOccurs="0">							<xs:annotation>								<xs:documentation>Indicates if the manipulation number comes from the Customs Streamliner  (T/F) (for example for automatic Inbound creation from Outbound)</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:enumeration value="F"/>									<xs:enumeration value="T"/>									<xs:enumeration value=""/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="dossierRemarks" minOccurs="0">							<xs:annotation>								<xs:documentation>Free remarks field for instructions</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="2000"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="Declarations" minOccurs="0">							<xs:annotation>								<xs:documentation>To include additional data for the declaration(s) that have to be made</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:choice>									<xs:element name="ThirdParty">										<xs:annotation>											<xs:documentation>The information when the declaration is made by a Third Party</xs:documentation>										</xs:annotation>										<xs:complexType>											<xs:sequence>												<xs:element name="ThirdParty" type="RelationType" minOccurs="0">													<xs:annotation>														<xs:documentation>Owner of the goods.  When owner is specified, stockprincipal or inboundprincipal should be specified in all dossiertypes which need to pick.</xs:documentation>													</xs:annotation>												</xs:element>												<xs:element name="customsDocumentNr"/>												<xs:element name="documentDate"/>												<xs:element name="typePartOne" minOccurs="0"/>												<xs:element name="typePartTwo" minOccurs="0"/>												<xs:element name="procedurePartOne" minOccurs="0"/>												<xs:element name="procedurePartTwo" minOccurs="0"/>												<xs:element name="nationalProcedure" minOccurs="0"/>												<xs:element name="procedureType" minOccurs="0"/>												<xs:element name="thirdPartyLocation" minOccurs="0"/>												<xs:element name="reference" minOccurs="0"/>											</xs:sequence>										</xs:complexType>									</xs:element>								</xs:choice>							</xs:complexType>						</xs:element>						<xs:element name="SSWDossier" minOccurs="0">							<xs:annotation>								<xs:documentation>Info that returns from the custom streamliner that contains information about the linked declarations with a dossier</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="dossierID" type="declarationIDType"/>									<xs:element name="statusDossier" type="dossierStatusType" minOccurs="0">										<xs:annotation>											<xs:documentation>The status of the dossier</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="substatusDossier" type="dossierStatusType" minOccurs="0"/>									<xs:element name="processID" type="declarationIDType" minOccurs="0">										<xs:annotation>											<xs:documentation>The internal ID of processing in streamliner</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="VariableChecks" minOccurs="0">										<xs:complexType>											<xs:sequence>												<xs:element name="VariableCheck" minOccurs="0" maxOccurs="unbounded">													<xs:complexType>														<xs:sequence>															<xs:element name="errorType" minOccurs="0">																<xs:annotation>																	<xs:documentation>The Type of the Check (Error/Warning)</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="dossierLineID" type="declarationIDType" minOccurs="0">																<xs:annotation>																	<xs:documentation>The Dossier Line ID which was checked</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="stockID" type="declarationIDType" minOccurs="0">																<xs:annotation>																	<xs:documentation>The Stock ID which was checked</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="checkName" minOccurs="0">																<xs:annotation>																	<xs:documentation>The name (ID) of the check</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="description">																<xs:annotation>																	<xs:documentation>The error description of the check</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="solution" minOccurs="0">																<xs:annotation>																	<xs:documentation>The solution of the check (if provided)</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="customerSolution" minOccurs="0">																<xs:annotation>																	<xs:documentation>The description of the customer (if provided)</xs:documentation>																</xs:annotation>															</xs:element>														</xs:sequence>													</xs:complexType>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>									<xs:element name="DeclarantAssistChecks" minOccurs="0">										<xs:complexType>											<xs:sequence>												<xs:element name="DeclarantAssistCheck" minOccurs="0" maxOccurs="unbounded">													<xs:complexType>														<xs:sequence>															<xs:element name="errorType">																<xs:annotation>																	<xs:documentation>The Type of the Check (Error/Warning)</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="dossierLineID" type="declarationIDType">																<xs:annotation>																	<xs:documentation>The Dossier Line ID which was checked</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="stockID" type="declarationIDType" minOccurs="0">																<xs:annotation>																	<xs:documentation>The Stock ID which was checked</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="dutyAsked" minOccurs="0">																<xs:annotation>																	<xs:documentation>The Duty that was requested by the current information</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="possibleBetterDuty" minOccurs="0">																<xs:annotation>																	<xs:documentation>The duty that could possibly be asked</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="docsRequired" minOccurs="0">																<xs:annotation>																	<xs:documentation>The documents that are still required</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="vatAsked" minOccurs="0">																<xs:annotation>																	<xs:documentation>The VAT asked by the current information</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="hasAntiDump" minOccurs="0">																<xs:annotation>																	<xs:documentation>Indicator that antidumping is found</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="supplUnitsNeeded" minOccurs="0">																<xs:annotation>																	<xs:documentation>Indicator that incorrect supplementary units are used and should be replaced by the given supplementary unit</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="additionalCodes" minOccurs="0">																<xs:annotation>																	<xs:documentation>The additional codes that are possible</xs:documentation>																</xs:annotation>															</xs:element>															<xs:element name="hasExcise" minOccurs="0">																<xs:annotation>																	<xs:documentation>Indicator that excise is found</xs:documentation>																</xs:annotation>															</xs:element>														</xs:sequence>													</xs:complexType>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>					</xs:sequence>				</xs:complexType>			</xs:element>			<xs:element name="GoodsItem" minOccurs="0" maxOccurs="unbounded">				<xs:complexType>					<xs:sequence>						<xs:element name="sequence" minOccurs="0">							<xs:annotation>								<xs:documentation>Unique number per line. Defines the order of the linesCan also be the invoiceline sequence</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="sequence">									<xs:fractionDigits value="0"/>									<xs:totalDigits value="5"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="linkId" minOccurs="0">							<xs:annotation>								<xs:documentation>Used when there needs to be a 1-1 relation on line level.  If updates are sent later.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:choice minOccurs="0">							<xs:element name="removeLine" type="booleanType" minOccurs="0">								<xs:annotation>									<xs:documentation>if true the line will be removed from Customs Streamliner.  linkID's MUST be specified!</xs:documentation>								</xs:annotation>							</xs:element>							<xs:element name="forceUpdateLine" minOccurs="0">								<xs:annotation>									<xs:documentation>Defines if zero/blank values should be considered on purpose (T/F)</xs:documentation>								</xs:annotation>							</xs:element>						</xs:choice>						<xs:element name="Principal" type="RelationType" minOccurs="0">							<xs:annotation>								<xs:documentation>Owner of the goods.  When owner is specified, stockprincipal or inboundprincipal should be specified in all dossiertypes which need to pick.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="Inbound" minOccurs="0">							<xs:annotation>								<xs:documentation>Specific fields for inbound</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence minOccurs="0">									<xs:choice>										<xs:element name="immediateClearance" type="booleanType" minOccurs="0" maxOccurs="0">											<xs:annotation>												<xs:documentation>True means the goods must be cleared on arrival of the warehouse.If true then stocktype must be FREE.  Please use arrivedStockType instead.</xs:documentation>											</xs:annotation>										</xs:element>										<xs:element name="arrivedStockType" type="stockTypeType" minOccurs="0">											<xs:annotation>												<xs:documentation>The type of stock which arrived.  If supplied on header level, this field will be ignored.</xs:documentation>											</xs:annotation>										</xs:element>									</xs:choice>									<xs:element name="stockType" type="stockTypeType" minOccurs="0">										<xs:annotation>											<xs:documentation>The stocktype in which formati this dossierline is kept in the warehouse. If supplied on header, this field will be ignored.</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="Mutation" minOccurs="0">										<xs:complexType>											<xs:sequence>												<xs:element name="mutateFromSerialNumber" minOccurs="0">													<xs:annotation>														<xs:documentation>Only supply if customs serialnumbers are REQUIRED by customs.  </xs:documentation>													</xs:annotation>													<xs:simpleType>														<xs:restriction base="xs:string">															<xs:maxLength value="35"/>														</xs:restriction>													</xs:simpleType>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>									<xs:element name="manipulationCode" type="manipulationCodeType" minOccurs="0">										<xs:annotation>											<xs:documentation>The manipulation code used when there is a difference between the current values for stockamount and weight and this one (only for GPA). CO - Negative Adjustment/Weight correctionsVM - Manual CorrectionMB - Positive Adjustment</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="CutOver" type="CutOverType" minOccurs="0"/>									<xs:element name="requireValidation" minOccurs="0">										<xs:annotation>											<xs:documentation>If this value is true, picking will not be allowed from this line.  Manual intervention or an update interface is required for continuing of the process.</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="PreviousDocument" minOccurs="0">										<xs:complexType>											<xs:sequence>												<xs:choice>													<xs:element name="AirLyst" minOccurs="0">														<xs:complexType>															<xs:sequence>																<xs:element name="airwayBillNr" type="previousDocumentBillOfLoading"/>															</xs:sequence>														</xs:complexType>													</xs:element>													<xs:element name="AirManifest" minOccurs="0">														<xs:complexType>															<xs:sequence>																<xs:element name="airwayBillNr" type="previousDocumentBillOfLoading"/>																<xs:element name="article" type="previousDocumentArt"/>															</xs:sequence>														</xs:complexType>													</xs:element>													<xs:element name="Maritime" minOccurs="0">														<xs:complexType>															<xs:sequence>																<xs:element name="article" type="previousDocumentArt" minOccurs="0">																	<xs:annotation>																		<xs:documentation>Martime, Air Manifest</xs:documentation>																	</xs:annotation>																</xs:element>																<xs:element name="item" type="previousDocumentItem" minOccurs="0"/>																<xs:element name="billOfLoading" type="previousDocumentBillOfLoading"/>															</xs:sequence>														</xs:complexType>													</xs:element>													<xs:element name="Warehouse" minOccurs="0">														<xs:complexType>															<xs:sequence>																<xs:element name="article" type="previousDocumentArt">																	<xs:annotation>																		<xs:documentation>Entrepot, stocksheetreference</xs:documentation>																	</xs:annotation>																</xs:element>															</xs:sequence>														</xs:complexType>													</xs:element>													<xs:element name="Rescue" minOccurs="0">														<xs:complexType>															<xs:sequence>																<xs:element name="article" type="previousDocumentArt">																	<xs:annotation>																		<xs:documentation>Martime, Air Manifest</xs:documentation>																	</xs:annotation>																</xs:element>																<xs:element name="item" type="previousDocumentItem">																	<xs:annotation>																		<xs:documentation>Martime</xs:documentation>																	</xs:annotation>																</xs:element>															</xs:sequence>														</xs:complexType>													</xs:element>												</xs:choice>											</xs:sequence>										</xs:complexType>									</xs:element>									<xs:element name="ArrivalEMCS" minOccurs="0">										<xs:complexType>											<xs:sequence>												<xs:element name="EmcsRor" type="EmcsRor" minOccurs="0"/>											</xs:sequence>										</xs:complexType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="Outbound" minOccurs="0">							<xs:annotation>								<xs:documentation>Only necessary for outbound</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence minOccurs="0">									<xs:element name="stockType" type="stockTypeType" minOccurs="0">										<xs:annotation>											<xs:documentation>Must be filled in when no smart picking is configured.</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="inboundHeaderLinkID" minOccurs="0">										<xs:annotation>											<xs:documentation>If this field is filled in, picking will only pick from this dossier. </xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:maxLength value="35"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="StockPrincipal" type="RelationType" minOccurs="0">										<xs:annotation>											<xs:documentation>When this relation is filled in, stock will first be picked from this principal, if supplied on line level through the interface.</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="InboundPrincipal" type="RelationType" minOccurs="0">										<xs:annotation>											<xs:documentation>If stock is not enough.  Stock will be taken from this principal if supplied on line level through the interface.</xs:documentation>										</xs:annotation>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="additionalScenario" minOccurs="0">							<xs:annotation>								<xs:documentation>MUTUAL agreed value.To use predefined declaration decisionsscenario.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="16"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="procedureFlow" minOccurs="0">							<xs:annotation>								<xs:documentation>DMS 4.1 related to manage chain arrangement:0.Default1.Normal Import Procedure2.No Chain Arrangement3.Chain Arrangement</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:integer">									<xs:totalDigits value="1"/>									<xs:enumeration value="0"/>									<xs:enumeration value="1"/>									<xs:enumeration value="2"/>									<xs:enumeration value="3"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="CustomProcedure" type="CustomProcedureType" minOccurs="0"/>						<xs:choice minOccurs="0">							<xs:annotation>								<xs:documentation>Choose whether the whole product is sent or only the product code</xs:documentation>							</xs:annotation>							<xs:element name="Product" type="ProductType" minOccurs="0"/>							<xs:element name="productCode" minOccurs="0">								<xs:simpleType>									<xs:restriction base="xs:string">										<xs:maxLength value="35"/>									</xs:restriction>								</xs:simpleType>							</xs:element>						</xs:choice>						<xs:element name="Commodity" type="CommodityType" minOccurs="0"/>						<xs:element name="AdditionalCommodity" minOccurs="0">							<xs:annotation>								<xs:documentation>These codes are stored transactionally on the dossierline.Use this only when you cannot store these codes on the commodity or on a product (product is master)Ex: product A is made by producer X and Y. Both suppliers have another Additional code for Antidumping.</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="firstAdditionalCommodity" minOccurs="0">										<xs:simpleType>											<xs:restriction base="firstAdditionalCommodity">												<xs:minLength value="4"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="secondAdditionalCommodity" minOccurs="0">										<xs:simpleType>											<xs:restriction base="secondAdditionalCommodity">												<xs:minLength value="4"/>												<xs:maxLength value="4"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="nationalAdditionalCommodity1" minOccurs="0">										<xs:simpleType>											<xs:restriction base="nationalAdditionalCommodity1">												<xs:minLength value="4"/>												<xs:maxLength value="4"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="nationalAdditionalCommodity2" minOccurs="0">										<xs:simpleType>											<xs:restriction base="nationalAdditionalCommodity2">												<xs:minLength value="4"/>												<xs:maxLength value="4"/>											</xs:restriction>										</xs:simpleType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="productIndicator" minOccurs="0">							<xs:annotation>								<xs:documentation>*only for logbook interface1 = Final Prodcut2 = Raw material</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:integer">									<xs:totalDigits value="1"/>									<xs:enumeration value="0"/>									<xs:enumeration value="1"/>									<xs:enumeration value="2"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="goodsDescription" minOccurs="0">							<xs:annotation>								<xs:documentation>If not filled in will be taken from product/commodity description</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="goodsDescription">									<xs:minLength value="1"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="originCountry" type="originCountry" minOccurs="0"/>						<xs:element name="preferentialOriginCountry" type="originCountry" minOccurs="0"/>						<xs:element name="pieces" minOccurs="0">							<xs:annotation>								<xs:documentation>*Mandaotry* if stock is in pieces</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:int">									<xs:totalDigits value="9"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="massesChecked" type="booleanType" minOccurs="0">							<xs:annotation>								<xs:documentation>Special switch when weights need to be validated, if true, weights are valid.  Ignore if not discussed.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="netMass1" minOccurs="0">							<xs:annotation>								<xs:documentation>Nettmass of 1 stock item</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="netMass">									<xs:totalDigits value="18"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="netMass" minOccurs="0">							<xs:annotation>								<xs:documentation>Nettmass of all stock items on this line.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="netMass">									<xs:totalDigits value="18"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="grossMass1" minOccurs="0">							<xs:annotation>								<xs:documentation>Grossmass of 1 stock item</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="grossMass">									<xs:totalDigits value="18"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="grossMass" minOccurs="0">							<xs:annotation>								<xs:documentation>Grossmass of all stock items on this line</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="grossMass">									<xs:totalDigits value="18"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="stockAmount" minOccurs="0">							<xs:annotation>								<xs:documentation>stockamount is mandatory > IF stock is NOT kept in pieces/packages or netmass.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="netMass">									<xs:totalDigits value="18"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="density" minOccurs="0">							<xs:annotation>								<xs:documentation>The density of the product on the line if it can't be defaulted on product</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="netMass">									<xs:totalDigits value="7"/>									<xs:fractionDigits value="2"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="alcoholicStrength" minOccurs="0">							<xs:annotation>								<xs:documentation>The alcoholic strength of the product on the line. Can be different from the alcoholic strength on the product.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="netMass">									<xs:totalDigits value="5"/>									<xs:fractionDigits value="2"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="fiscalMark" minOccurs="0">							<xs:annotation>								<xs:documentation>The Fiscal Mark for the EMCS declaration</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="350"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="Price" minOccurs="0">							<xs:annotation>								<xs:documentation>If no customs value is provided, price must be filled together with the charges.</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="price">										<xs:annotation>											<xs:documentation>price is the total price of all stockitems of this GoodsItem</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="price">												<xs:totalDigits value="18"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="ExchangeRate" type="ExchangeRateType" minOccurs="0">										<xs:annotation>											<xs:documentation>Deprecated: Do not use. Use on GoodsHeader level only.</xs:documentation>										</xs:annotation>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="FiscalPrice" minOccurs="0">							<xs:annotation>								<xs:documentation>FiscalPrice for fiscal representation.</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="price">										<xs:annotation>											<xs:documentation>price is the total fiscalprice. (sales value)</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="price">												<xs:totalDigits value="18"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="ExchangeRate" type="ExchangeRateType" minOccurs="0">										<xs:annotation>											<xs:documentation>Deprecated: Do not use. Use on GoodsHeader level only.</xs:documentation>										</xs:annotation>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="Charges" type="ChargesType" minOccurs="0">							<xs:annotation>								<xs:documentation>Charges to calculate the customs value.  Not the complete charges on the invoice.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="customsValue" type="statisticalValue" minOccurs="0">							<xs:annotation>								<xs:documentation>For inbound and import customs value is required, can be calculated by filling in price and charges.  Value of goods on border of EUCalculation will be done based on price, charges,...</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="statisticalValueAdjustment" type="statisticalValueAdjustment" minOccurs="0">							<xs:annotation>								<xs:documentation>Adjustment on the statistical value.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="statisticalValue" type="statisticalValue" minOccurs="0">							<xs:annotation>								<xs:documentation>Value of the goods on the border of home country.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="Packaging" type="PackagingType" minOccurs="0"/>						<xs:element name="SupplementaryUnits" type="SupplementaryUnitsType" minOccurs="0"/>						<xs:element name="containerIdentifier" minOccurs="0" maxOccurs="99">							<xs:simpleType>								<xs:restriction base="containerIdentifier"/>							</xs:simpleType>						</xs:element>						<xs:element name="VariableFields" minOccurs="0">							<xs:annotation>								<xs:documentation>Fields defined by the customer</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="VariableField" type="VariableFieldType" maxOccurs="unbounded"/>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="AdditionalDocuments" minOccurs="0">							<xs:annotation>								<xs:documentation>CADDDOC moduleCustomer defined documents can be transmitted here</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="AdditionalDocument" maxOccurs="unbounded">										<xs:complexType>											<xs:sequence>												<xs:element name="documentType">													<xs:simpleType>														<xs:restriction base="xs:string">															<xs:maxLength value="35"/>														</xs:restriction>													</xs:simpleType>												</xs:element>												<xs:element name="reference">													<xs:simpleType>														<xs:restriction base="xs:string">															<xs:maxLength value="35"/>														</xs:restriction>													</xs:simpleType>												</xs:element>											</xs:sequence>										</xs:complexType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="ProducedDocument" minOccurs="0" maxOccurs="unbounded">							<xs:annotation>								<xs:documentation>Any special customs documents can be transmitted here (for example a Form A)</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:sequence>									<xs:element name="Document">										<xs:complexType>											<xs:sequence>												<xs:element name="documentReference">													<xs:annotation>														<xs:documentation>the length of the reference is depending on the type of declaration that will be made. Ex.PLDA= 35charEMCS= 350char...</xs:documentation>													</xs:annotation>													<xs:simpleType>														<xs:restriction base="xs:string">															<xs:maxLength value="350"/>														</xs:restriction>													</xs:simpleType>												</xs:element>												<xs:element name="documentReferenceLanguage" type="languagecode" minOccurs="0"/>												<xs:choice>													<xs:element name="dossierDocumentType">														<xs:annotation>															<xs:documentation>Mutual agreed value for crossreferencing</xs:documentation>														</xs:annotation>														<xs:simpleType>															<xs:restriction base="xs:string">																<xs:maxLength value="16"/>															</xs:restriction>														</xs:simpleType>													</xs:element>													<xs:element name="documentType">														<xs:annotation>															<xs:documentation>fixed plda Codes</xs:documentation>														</xs:annotation>														<xs:simpleType>															<xs:restriction base="xs:string">																<xs:maxLength value="4" fixed="true"/>															</xs:restriction>														</xs:simpleType>													</xs:element>													<xs:element name="emcsDocumentType">														<xs:annotation>															<xs:documentation>Used only for creating an EMCS departure</xs:documentation>														</xs:annotation>														<xs:simpleType>															<xs:restriction base="xs:string">																<xs:maxLength value="16"/>															</xs:restriction>														</xs:simpleType>													</xs:element>												</xs:choice>												<xs:element name="documentTypeLanguage" type="languagecode" minOccurs="0"/>											</xs:sequence>										</xs:complexType>									</xs:element>									<xs:element name="producedDocumentsValidationOffice" minOccurs="0">										<xs:simpleType>											<xs:restriction base="ProducedDocumentsValidationOffice"/>										</xs:simpleType>									</xs:element>									<xs:element name="producedDocumentsInformationDate" type="ProducedDocumentsInformationDate" minOccurs="0"/>									<xs:element name="producedDocumentsValidTillDate" type="ProducedDocumentsInformationDate" minOccurs="0">										<xs:annotation>											<xs:documentation>Used for indicating the validity of a doucument (example for a U164 certificate)</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="ArchiveInformation" type="TArchiveInformation" minOccurs="0"/>									<xs:element name="DocumentQuantity" type="TDocumentQuantity" minOccurs="0"/>									<xs:element name="complementaryInformation" minOccurs="0">										<xs:simpleType>											<xs:restriction base="complementaryInformationProduced">												<xs:maxLength value="25"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="originCriterion" minOccurs="0">										<xs:annotation>											<xs:documentation>P: Product wholly obtainedW: Product sufficiently worked or processed</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:length value="1"/>												<xs:pattern value="P"/>												<xs:pattern value="W"/>											</xs:restriction>										</xs:simpleType>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="oprReference" minOccurs="0">							<xs:annotation>								<xs:documentation>Outward processing relief reference for identification for  receving goods on inbound.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="materialCost" type="statisticalValue" minOccurs="0">							<xs:annotation>								<xs:documentation>If the marerialvalue for the opr is known.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="additionalRangeField1" minOccurs="0">							<xs:annotation>								<xs:documentation>the Picking of an outbound dossier will be done within the specific range specified on the inbound</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="35"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="storageLocation" type="storageLocation" minOccurs="0">							<xs:annotation>								<xs:documentation>If on outbound a special range of inbound must be specified, this field can be used for it.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="valuationMethod" minOccurs="0">							<xs:annotation>								<xs:documentation>If supplied, the specific method of valuation will be used.</xs:documentation>							</xs:annotation>							<xs:simpleType>								<xs:restriction base="xs:string">									<xs:maxLength value="16"/>									<xs:enumeration value="INVOICE"/>									<xs:enumeration value="DEDUCTED"/>									<xs:enumeration value="UNITY"/>									<xs:enumeration value="FIXED"/>									<xs:enumeration value="BANANA"/>									<xs:enumeration value="RETROGRADE"/>									<xs:enumeration value="FALLBACK"/>								</xs:restriction>							</xs:simpleType>						</xs:element>						<xs:element name="Licensing" minOccurs="0">							<xs:complexType>								<xs:sequence>									<xs:element name="useQuota" type="booleanType" minOccurs="0">										<xs:annotation>											<xs:documentation>If supplied, licencing will only be checked but not reserved.</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="holderLicense" type="RelationType" minOccurs="0">										<xs:annotation>											<xs:documentation>if supplied, the licenses of this party will be used for importing</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="licenceNumber" minOccurs="0">										<xs:annotation>											<xs:documentation>If supplied only this license number will be picked.</xs:documentation>										</xs:annotation>										<xs:simpleType>											<xs:restriction base="xs:string">												<xs:maxLength value="35"/>											</xs:restriction>										</xs:simpleType>									</xs:element>									<xs:element name="quota" type="quota" minOccurs="0">										<xs:annotation>											<xs:documentation>Only supply if using quota</xs:documentation>										</xs:annotation>									</xs:element>									<xs:element name="BioHolderLicense" type="RelationType" minOccurs="0">										<xs:annotation>											<xs:documentation>If supplied, the bio licenses of this party will be used.</xs:documentation>										</xs:annotation>									</xs:element>								</xs:sequence>							</xs:complexType>						</xs:element>						<xs:element name="WriteOffDocuments" type="WriteOffDocumentsType" minOccurs="0">							<xs:annotation>								<xs:documentation>Write Off documents link to item in returning message</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="PickingResults" type="PickingResultsType" minOccurs="0">							<xs:annotation>								<xs:documentation>Result of picking process in returning messages.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="BatchReportLines" minOccurs="0">							<xs:annotation>								<xs:documentation>Messages in returning messages.</xs:documentation>							</xs:annotation>							<xs:complexType>								<xs:complexContent>									<xs:extension base="BatchReportLinesType"/>								</xs:complexContent>							</xs:complexType>						</xs:element>						<xs:element name="pickRepacked" type="booleanType" minOccurs="0">							<xs:annotation>								<xs:documentation>Indicates the delivery is from repacked stock.  Usually only for outbound dossiers.</xs:documentation>							</xs:annotation>						</xs:element>						<xs:element name="ignoreReportLevel" minOccurs="0">							<xs:annotation>								<xs:documentation>The specified report and all higher report levels will be ignored.  example: 3 (warning)  all warnings (3) and errors (4) will be ignored.</xs:docu