		</xs:restriction>
	</xs:simpleType>
	<!--DV1 box 8(a) -->
	<xs:simpleType name="restrictions">
		<xs:annotation>
			<xs:documentation>This element is used to indicate the response in terms of Yes/No/NA independent of case.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="code">
			<xs:minLength value="2"/>
			<xs:maxLength value="3"/>
		</xs:restriction>
	</xs:simpleType>
	<!--DV1 box 8(b) -->
	<xs:simpleType name="consideration">
		<xs:annotation>
			<xs:documentation>This element is used to indicate the response in terms of Yes/No/NA independent of case.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="code">
			<xs:minLength value="2"/>
			<xs:maxLength value="3"/>
		</xs:restriction>
	</xs:simpleType>
	<!--DV1 box 8(text field) -->
	<xs:simpleType name="restrictCondDetails">
		<xs:restriction base="xs:string">
			<xs:maxLength value="300"/>
		</xs:restriction>
	</xs:simpleType>
	<!--DV1 box 9(a) -->
	<xs:simpleType name="royalties">
		<xs:annotation>
			<xs:documentation>This element is used to indicate the response in terms of Yes/No/NA independent of case.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="code">
			<xs:minLength value="2"/>
			<xs:maxLength value="3"/>
		</xs:restriction>
	</xs:simpleType>
	<!--DV1 box 9(b) -->
	<xs:simpleType name="resale">
		<xs:annotation>
			<xs:documentation>This element is used to indicate the response in terms of Yes/No/NA independent of case.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="code">
			<xs:minLength value="2"/>
			<xs:maxLength value="3"/>
		</xs:restriction>
	</xs:simpleType>
	<!--DV1 box 9(conditions details)-->
	<xs:simpleType name="conditions">
