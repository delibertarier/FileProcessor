	<!-- TProcedureGlobImport added under e-Globalization -->
	<xs:complexType name="TProcedureGlobImport">
		<xs:annotation>
			<xs:documentation>
        SAD REF - Box 37 - 44 Procedure DESC - The procedure for which the goods are declared. BOX 37 Code is in three parts : Part
        1A - First 2 digits. The procedure for which the goods are declared (Community Code) Part 1B - Second 2 digits (Previous
        Customs procedure, coded) Part 2 - Procedure code (Community procedure, coded BOX44 2 additional codes
      </xs:documentation>
		</xs:annotation>
