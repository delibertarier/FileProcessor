			<xs:element name="additionalInformationContentEnergy" type="TAdditionalInformationContentEnergy" minOccurs="0"/>
			<xs:element name="additionalInformationType">
				<xs:simpleType>
					<xs:restriction base="additionalInformationType">
						<xs:minLength value="1"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
		<!-- Added by Steve Geudens for AC4 -->
	</xs:complexType>
	<xs:complexType name="TPreviousDocumentAC4">
		<xs:sequence>
			<xs:element name="Document" type="TPreviousDocument"/>
			<xs:element name="previousDocumentDate" type="previousDocumentDate" minOccurs="0"/>
			<xs:element name="previousDocumentArt" type="previousDocumentArt" minOccurs="0"/>
		</xs:sequence>
		<!-- Added by Steve Geudens for AC4 -->
	</xs:complexType>
	<xs:complexType name="TProducedDocumentAC4">
		<xs:sequence>
			<xs:element name="Document" type="TProducedDocument"/>
			<xs:element name="producedDocumentsInformationDate" type="ProducedDocumentsInformationDate" minOccurs="0"/>
			<xs:element name="complementaryInformation" minOccurs="0">
				<xs:simpleType>
					<xs:restriction base="complementaryInformationProduced">
						<xs:maxLength value="25"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
		<!-- Added by Steve Geudens for AC4 -->
	</xs:complexType>
	<xs:complexType name="TAdditionalInformationContentEnergy">
		<xs:sequence>
			<xs:element name="additionalInformationLicenseNumber">
				<xs:simpleType>
					<xs:restriction base="additionalInformationLicenseNumber">
						<xs:minLength value="1"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="additionalInformationProductCode">
				<xs:simpleType>
					<xs:restriction base="additionalInformationProductCode">
						<xs:minLength value="1"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
		</xs:sequence>
		<!-- Added by Steve Geudens for AC4 -->
	</xs:complexType>
	<xs:complexType name="TProcedureAC4">
		<xs:sequence>
			<xs:element name="procedurePart1" type="procedurePart1"/>
			<xs:element name="procedurePart2" type="procedurePart2"/>
		</xs:sequence>
		<!-- Added by Steve Geudens for AC4 -->
	</xs:complexType>
	<!--DV1(Customs Value) header level elements-->
	<xs:complexType name="TDV1DeclarationHeader">
		<xs:annotation>
			<xs:documentation>The necessary information for DV1 on header level, i.e. information which is valid for all articles of the SAD declaration.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<!--Name, Address and Identification of Seller in Block Letters-->
			<xs:element name="Seller" type="TOperator" minOccurs="0"/>
			<!--Name, Address and Identification of Buyer in Block Letters-->
			<xs:element name="Buyer" type="TOperator"/>
			<!--Number and Date of Contract-->
			<xs:element name="Contract" type="TContract"/>
			<!--Number and date of any previous Customs Decisions concerning boxes 7 to 9 of a DV1 Declaration-->
			<xs:element name="PreviousCustomsDecision" type="TPreviousCustomsDecision" minOccurs="0"/>
			<!--Box B - QUOTE BELOW previous relevant Customs decisions, if any-->
			<xs:element name="costRelatedPrevCustDecisions" type="costRelatedPrevCustDecisions" minOccurs="0"/>
			<!--Particulars about the relationship between Buyer and Seeler and its influence on prices of imported goods-->
			<xs:element name="BuyerSellerRelation" type="TBuyerSellerRelation" minOccurs="0"/>
			<!--Particulars about possible Restrictions from Buyer's side. Conditions or Considerations for the goods being valued-->
			<xs:element name="RestrictionsAndConditions" type="TRestrictionsAndConditions" minOccurs="0"/>
			<!--Royalties or Licence Fees related to imported goods payable by Buyer either directly or indirectly as a condition of the sale-->
			<xs:element name="RoyaltiesAndResale" type="TRoyaltiesAndResale" minOccurs="0"/>
			<!--Place of the signature or stmap  -->
			<xs:element name="Signature" type="TSignature" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 goodsItem level details-->
	<xs:complexType name="TDV1Detail">
		<xs:annotation>
			<xs:documentation>The necessary information for DV1 on goodsItem level, i.e. information which is valid for concerned article of the SAD declaration.</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<!--Box A - Basis of Calculation  -->
			<xs:element name="CalcBasis" type="TCalcBasis" minOccurs="0"/>
			<!--Box B - Costs not included in Box A-->
			<xs:element name="Additions" type="TAdditions" minOccurs="0"/>
			<!--Box C - Deductions included in Box A-->
			<xs:element name="Deductions" type="TDeductions" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box 5-->
	<xs:complexType name="TContract">
		<xs:annotation>
			<xs:documentation>Box 5 - Number and date of contract</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<!--5.1 Number of contract-->
			<xs:element name="contractNumber" type="contractNumber"/>
			<!--5.1 Date of contract-->
			<xs:element name="contractDate" type="contractDate"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box 6-->
	<xs:complexType name="TPreviousCustomsDecision">
		<xs:annotation>
			<xs:documentation>Box 6 - Number and date of any previous Customs Decision concerning boxes 7 to 9 of a DV1 Declaration</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:element name="prevCustDecisionNumber" type="prevCustDecisionNumber" minOccurs="0"/>
			<xs:element name="prevCustDecisionDate" type="prevCustDecisionDate" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box 7-->
	<xs:complexType name="TBuyerSellerRelation">
		<xs:annotation>
			<xs:documentation>Box 7 - Buyer and Seller relation and comparable transaction value</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<!--7. a) Are the buyer and seller RELATED in the sense of Article 143 (*) of Regulation (EEC) No 2454/93? If 'NO', go to box 9.-->
			<xs:element name="relation" type="relation" minOccurs="0"/>
			<!--7. b) Did the relationship INFLUENCE the price of the imported goods?-->
			<xs:element name="influence" type="influence" minOccurs="0"/>
			<!--7. c.1) (reply optional) Does the transaction value of the imported goods CLOSELY APPROXIMATE to a value mentioned in Article 29 (2) (b) of Regulation (EEC) No 2913/92?-->
			<xs:element name="closeApproximate" type="closeApproximate" minOccurs="0"/>
			<!--7. c.2) If "YES", give details:-->
			<xs:element name="closeApprxDetails" type="closeApprxDetails" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box 8-->
	<xs:complexType name="TRestrictionsAndConditions">
		<xs:annotation>
			<xs:documentation>Box 8 - Limitations, conditions and considerations</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<!--8. a) Are there any RESTRICTIONS as to the disposition or use of the goods by the buyer, other than restrictions which:
					- are imposed or required by law or by the public authorities in the Community,
					- Limit the geographical area in which the goods may be resold, or
					- do not substantially affect the value of the goods?-->
			<xs:element name="restrictions" type="restrictions" minOccurs="0"/>
			<!--8. b) Is the sale or price subject to some CONDITION or CONSIDERATION for which a value cannot be determined with respect to the goods being valued?-->
			<xs:element name="consideration" type="consideration" minOccurs="0"/>
			<!--8. Specify the nature of restrictions, conditions, considerations as appropriate-->
			<xs:element name="restrictCondDetails" type="restrictCondDetails" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box 9-->
	<xs:complexType name="TRoyaltiesAndResale">
		<xs:annotation>
			<xs:documentation>Box 9 - Royalties, license fees and resale</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<!--9. a) Are any ROYALTIES and LICENCE FEES related to the imported goods payable either directly or indirectlyby the buyer as a condition of the sale?-->
			<xs:element name="royalties" type="royalties" minOccurs="0"/>
			<!--9. b) Is the sale subject to an arrangement under which part of the proceeds of any subsequent RESALE, DISPOSAL or USE accrues directly or indirectly to the seller?-->
			<xs:element name="resale" type="resale" minOccurs="0"/>
			<!--9. If 'YES' to either of these questions, specify conditions and, if possible, indicate the amounts in boxes 15 and 16.-->
			<xs:element name="conditions" type="conditions" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box 10(b)-->
	<xs:complexType name="TSignature">
		<xs:annotation>
			<xs:documentation>Box 10(b) - Signature details - place of signature/stamp</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<!--10. b1) Place-->
			<xs:element name="place" type="place" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box A-->
	<xs:complexType name="TCalcBasis">
		<xs:annotation>
			<xs:documentation>Box A Basis of calculations</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:annotation>
				<xs:documentation>11(b) Indirect Payments - see box 8(b)</xs:documentation>
			</xs:annotation>
			<!--11. b) Indirect payments- see box 8 (b)-->
			<xs:element name="IndirectPayments" type="TInvoice" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box B-->
	<xs:complexType name="TAdditions">
		<xs:annotation>
			<xs:documentation>Box B - Costs not included in Box A to be specified under various heads as categorized below</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<!--13. Costs incurred by the buyer-->
			<xs:element name="BuyerCosts" type="TBuyerCosts" minOccurs="0"/>
			<!--14. Goods and services supplied by the buyer free of charge or at reduced cost for use in connection with the production and sale for export of the imported goods: 
                    The values shown represent an appotionment where appropriate-->
			<xs:element name="BuyerGoodsServices" type="TBuyerGoodsServices" minOccurs="0"/>
			<!-- <xs:annotation>
                <xs:documentation>Box 15 - Royalties, license fees- see box 9 a)</xs:documentation>
            </xs:annotation> -->
			<!--15. Royalties, license fees- see box 9 a)-->
			<xs:element name="Royalties" type="TInvoice" minOccurs="0"/>
			<!-- <xs:annotation>
                <xs:documentation>Box 16 - Proceeds or any subsequent resale, disposal or use accruing to the seller- see box 9 b)</xs:documentation>
            </xs:annotation> -->
			<!--16. Proceeds or any subsequent resale, disposal or use accruing to the seller- see box 9 b)-->
			<xs:element name="Proceeds" type="TInvoice" minOccurs="0"/>
			<!--17. Costs of delivery to (place of introduction)-->
			<xs:element name="DeliveryCost" type="TDeliveryCost" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box C-->
	<xs:complexType name="TDeductions">
		<xs:annotation>
			<xs:documentation>Box C - Costs included in Box A but to be deducted under various heads as categorized below</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<xs:annotation>
				<xs:documentation>Box 19 - Costs of transport after arrival at place of introduction</xs:documentation>
			</xs:annotation>
			<!--19. Costs of transport after arrival at place of introduction-->
			<xs:element name="TransportAfterArrival" type="TInvoice" minOccurs="0"/>
			<!-- <xs:annotation>
                <xs:documentation>Box 20 - Charges for construction, erection, assembly, maintenance or technical assistance undertaken after importation</xs:documentation>
            </xs:annotation> -->
			<!--20. Charges for construction, erection, assembly, maintenance or technical assistance undertaken after importation.-->
			<xs:element name="ChargesAfterImport" type="TInvoice" minOccurs="0"/>
			<!--21. Other charges(specify) -->
			<xs:element name="OtherCharges" type="TOtherCharges" minOccurs="0"/>
			<!-- <xs:annotation>
                <xs:documentation>Box 22 - Customs duties and taxes payable in the Community by reason of the importation or sale of the goods</xs:documentation>
            </xs:annotation> -->
			<!--22. Customs duties and taxes payable in the Community by reason of the importation or sale of the goods-->
			<xs:element name="ImportDutiesAndTaxes" type="TInvoice" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box 13-->
	<xs:complexType name="TBuyerCosts">
		<xs:annotation>
			<xs:documentation>Box 13 - Costs incurred by the buyer</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<!--13. a) Commissions, except buying commissions-->
			<xs:element name="Commissions" type="TInvoice" minOccurs="0"/>
			<!--13. b) Brokerage-->
			<xs:element name="Brokerage" type="TInvoice" minOccurs="0"/>
			<!--13. c) Containers and packaging-->
			<xs:element name="Containers" type="TInvoice" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box 14-->
	<xs:complexType name="TBuyerGoodsServices">
		<xs:annotation>
			<xs:documentation>Box 14 - Goods and services supplied by the buyer free of charge or at reduced cost for use in connection with the production and sale for export of the imported goods: The values shown represent an appotionment where appropriate</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<!--14. a) Value of materials, components, parts and similar items incorporated in the imported goods-->
			<xs:element name="MaterialsIncorporated" type="TInvoice" minOccurs="0"/>
			<!--14. b) Value of tools, dies, moulds and similar items used in the production of the imported goods-->
			<xs:element name="Tools" type="TInvoice" minOccurs="0"/>
			<!--14. c) Value of materials consumed in the production of the imported goods-->
			<xs:element name="MaterialsConsumed" type="TInvoice" minOccurs="0"/>
			<!--14. d) Value of engineering, development, artwork, design work and plans and sketches undertaken elsewhere than in the Community and necessary for the production of the imported goods-->
			<xs:element name="Engineering" type="TInvoice" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box 17-->
	<xs:complexType name="TDeliveryCost">
		<xs:annotation>
			<xs:documentation>Box 17 - Costs of delivery to (place of introduction)</xs:documentation>
		</xs:annotation>
		<xs:sequence>
			<!--17. Place of introduction-->
			<xs:element name="placeOfIntro" type="place" minOccurs="0"/>
			<!--17 a) Costs of the transport-->
			<xs:element name="Transport" type="TInvoice" minOccurs="0"/>
			<!--17 b) Loading and handling of charges-->
			<xs:element name="LoadingAndHandling" type="TInvoice" minOccurs="0"/>
			<!--17 c) Insurance costs-->
			<xs:element name="Insurance" type="TInvoice" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 Box 21-->
	<xs:complexType name="TOtherCharges">
		<xs:sequence>
			<!--21. Other charges -->
			<xs:element name="OtherCosts" type="TInvoice" minOccurs="0"/>
			<!--21. Details of other charges-->
			<xs:element name="specification" type="specification" minOccurs="0"/>
		</xs:sequence>
	</xs:complexType>
	<!--DV1 box 5 -->
	<xs:simpleType name="contractDate">
		<xs:restriction base="TDate"/>
	</xs:simpleType>
	<!--DV1 box 5 -->
	<xs:simpleType name="contractNumber">
		<xs:restriction base="xs:string">
			<xs:maxLength value="20"/>
		</xs:restriction>
	</xs:simpleType>
	<!--DV1 box 6 -->
	<xs:simpleType name="prevCustDecisionNumber">
		<xs:restriction base="xs:string">
			<xs:maxLength value="20"/>
		</xs:restriction>
	</xs:simpleType>
	<!--DV1 box 6 -->
	<xs:simpleType name="prevCustDecisionDate">
		<xs:restriction base="TDate"/>
	</xs:simpleType>
	<!--DV1 box 7(a) -->
	<xs:simpleType name="relation">
		<xs:annotation>
			<xs:documentation>This element is used to indicate the response in terms of Yes/No/NA independent of case.
            </xs:documentation>
		</xs:annotation>
		<xs:restriction base="code">
			<xs:minLength value="2"/>
			<xs:maxLength value="3"/>
		</xs:restriction>
	</xs:simpleType>
	<!--DV1 box 7(b) -->
	<xs:simpleType name="influence">
		<xs:annotation>
			<xs:documentation>This element is used to indicate the response in terms of Yes/No/NA independent of case.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="code">
			<xs:minLength value="2"/>
			<xs:maxLength value="3"/>
		</xs:restriction>
	</xs:simpleType>
	<!--DV1 box 7(c) -->
	<xs:simpleType name="closeApproximate">
		<xs:annotation>
			<xs:documentation>This element is used to indicate the response in terms of Yes/No/NA independent of case.</xs:documentation>
		</xs:annotation>
		<xs:restriction base="code">
			<xs:minLength value="2"/>
			<xs:maxLength value="3"/>
